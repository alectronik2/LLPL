// Standard library: File I/O
// Namespace: std::io

namespace std {
namespace io {

// File open modes
const O_RDONLY: i64 = 0
const O_WRONLY: i64 = 1
const O_RDWR: i64 = 2
const O_CREAT: i64 = 64
const O_TRUNC: i64 = 512
const O_APPEND: i64 = 1024

// Seek positions
const SEEK_SET: i64 = 0
const SEEK_CUR: i64 = 1
const SEEK_END: i64 = 2

// Error codes
const ERR_FILE_NOT_FOUND: i64 = -1
const ERR_PERMISSION_DENIED: i64 = -2
const ERR_IO_ERROR: i64 = -3

// Forward declarations for C runtime
extern func open(path: u8*, flags: i64, mode: i64) -> i64
extern func close(fd: i64) -> i64
extern func read(fd: i64, buf: u8*, count: u64) -> i64
extern func write(fd: i64, buf: u8*, count: u64) -> i64
extern func lseek(fd: i64, offset: i64, whence: i64) -> i64
extern func unlink(path: u8*) -> i64
extern func rename(oldpath: u8*, newpath: u8*) -> i64

// File class with RAII semantics
class File {
    let fd: i64
    let path: String
    let is_open: bool

    constructor(filepath: u8*, flags: i64) {
        self.path = new String(filepath)
        self.fd = open(filepath, flags, 0o644)
        self.is_open = self.fd >= 0
    }

    constructor(filepath: u8*, flags: i64, mode: i64) {
        self.path = new String(filepath)
        self.fd = open(filepath, flags, mode)
        self.is_open = self.fd >= 0
    }

    destructor() {
        if self.is_open {
            close(self.fd)
        }
    }

    func is_valid() -> bool {
        return self.is_open
    }

    func read_bytes(buffer: u8*, size: u64) -> Result<i64, u8*> {
        let result: Result<i64, u8*> = new Result<i64, u8*>()

        if !self.is_open {
            result.set_err("File not open")
            return result
        }

        let bytes_read: i64 = read(self.fd, buffer, size)
        if bytes_read < 0 {
            result.set_err("Read error")
        } else {
            result.set_ok(bytes_read)
        }

        return result
    }

    func write_bytes(buffer: u8*, size: u64) -> Result<i64, u8*> {
        let result: Result<i64, u8*> = new Result<i64, u8*>()

        if !self.is_open {
            result.set_err("File not open")
            return result
        }

        let bytes_written: i64 = write(self.fd, buffer, size)
        if bytes_written < 0 {
            result.set_err("Write error")
        } else {
            result.set_ok(bytes_written)
        }

        return result
    }

    func read_string(max_size: u64) -> Result<String, u8*> {
        let result: Result<String, u8*> = new Result<String, u8*>()

        if !self.is_open {
            result.set_err("File not open")
            return result
        }

        let buffer: u8* = llpl_alloc(max_size + 1)
        let bytes_read: i64 = read(self.fd, buffer, max_size)

        if bytes_read < 0 {
            llpl_free(buffer)
            result.set_err("Read error")
            return result
        }

        buffer[bytes_read] = '\0'
        let s: String = new String(buffer)
        llpl_free(buffer)
        result.set_ok(s)

        return result
    }

    func write_string(s: String) -> Result<i64, u8*> {
        return self.write_bytes(s.c_str(), s.len() as u64)
    }

    func seek(offset: i64, whence: i64) -> Result<i64, u8*> {
        let result: Result<i64, u8*> = new Result<i64, u8*>()

        if !self.is_open {
            result.set_err("File not open")
            return result
        }

        let pos: i64 = lseek(self.fd, offset, whence)
        if pos < 0 {
            result.set_err("Seek error")
        } else {
            result.set_ok(pos)
        }

        return result
    }

    func tell() -> Result<i64, u8*> {
        return self.seek(0, SEEK_CUR)
    }

    func size() -> Result<i64, u8*> {
        let current_pos_result: Result<i64, u8*> = self.tell()
        if !current_pos_result.is_ok() {
            return current_pos_result
        }
        let current_pos: i64 = current_pos_result.unwrap()

        let end_pos_result: Result<i64, u8*> = self.seek(0, SEEK_END)
        if !end_pos_result.is_ok() {
            return end_pos_result
        }
        let file_size: i64 = end_pos_result.unwrap()

        // Restore position
        self.seek(current_pos, SEEK_SET)

        let result: Result<i64, u8*> = new Result<i64, u8*>()
        result.set_ok(file_size)
        return result
    }

    func read_all() -> Result<String, u8*> {
        let size_result: Result<i64, u8*> = self.size()
        if !size_result.is_ok() {
            let result: Result<String, u8*> = new Result<String, u8*>()
            result.set_err("Cannot get file size")
            return result
        }

        let file_size: i64 = size_result.unwrap()
        self.seek(0, SEEK_SET)

        return self.read_string(file_size as u64)
    }

    func flush() -> bool {
        // Note: Would call fsync(self.fd) if available
        return true
    }
}

// Utility functions
func read_file(path: u8*) -> Result<String, u8*> {
    let f: File = new File(path, O_RDONLY)
    let result: Result<String, u8*> = new Result<String, u8*>()

    if !f.is_valid() {
        result.set_err("Cannot open file")
        return result
    }

    return f.read_all()
}

func write_file(path: u8*, content: String) -> Result<i64, u8*> {
    let f: File = new File(path, O_WRONLY | O_CREAT | O_TRUNC)
    let result: Result<i64, u8*> = new Result<i64, u8*>()

    if !f.is_valid() {
        result.set_err("Cannot open file")
        return result
    }

    return f.write_string(content)
}

func append_file(path: u8*, content: String) -> Result<i64, u8*> {
    let f: File = new File(path, O_WRONLY | O_CREAT | O_APPEND)
    let result: Result<i64, u8*> = new Result<i64, u8*>()

    if !f.is_valid() {
        result.set_err("Cannot open file")
        return result
    }

    return f.write_string(content)
}

func file_exists(path: u8*) -> bool {
    let f: File = new File(path, O_RDONLY)
    return f.is_valid()
}

func delete_file(path: u8*) -> bool {
    return unlink(path) == 0
}

func rename_file(oldpath: u8*, newpath: u8*) -> bool {
    return rename(oldpath, newpath) == 0
}

} // namespace io
} // namespace std
