// Standard library: Binary Heap (Priority Queue)
// Namespace: std::collections

namespace std {
namespace collections {

// Min-heap implementation
// For max-heap, negate values when inserting/extracting
class BinaryHeap<T> {
    let data: Vector<T>

    constructor() {
        self.data = new Vector<T>()
    }

    func size() -> i64 {
        return self.data.len()
    }

    func is_empty() -> bool {
        return self.data.len() == 0
    }

    // Helper: Get parent index
    func parent(index: i64) -> i64 {
        return (index - 1) / 2
    }

    // Helper: Get left child index
    func left_child(index: i64) -> i64 {
        return 2 * index + 1
    }

    // Helper: Get right child index
    func right_child(index: i64) -> i64 {
        return 2 * index + 2
    }

    // Helper: Swap two elements
    func swap(i: i64, j: i64) {
        let temp: T = self.data.get(i)
        self.data.set(i, self.data.get(j))
        self.data.set(j, temp)
    }

    // Bubble up element at index
    func bubble_up(index: i64) {
        while index > 0 {
            let parent_idx: i64 = self.parent(index)

            if self.data.get(index) < self.data.get(parent_idx) {
                self.swap(index, parent_idx)
                index = parent_idx
            } else {
                break
            }
        }
    }

    // Bubble down element at index
    func bubble_down(index: i64) {
        let size: i64 = self.data.len()

        while true {
            let smallest: i64 = index
            let left: i64 = self.left_child(index)
            let right: i64 = self.right_child(index)

            if left < size && self.data.get(left) < self.data.get(smallest) {
                smallest = left
            }

            if right < size && self.data.get(right) < self.data.get(smallest) {
                smallest = right
            }

            if smallest != index {
                self.swap(index, smallest)
                index = smallest
            } else {
                break
            }
        }
    }

    // Insert element into heap
    func insert(value: T) {
        self.data.push(value)
        self.bubble_up(self.data.len() - 1)
    }

    // Remove and return minimum element
    func extract_min() -> Result<T, char*> {
        let result: Result<T, char*> = new Result<T, char*>()

        if self.is_empty() {
            result.set_err("Heap is empty")
            return result
        }

        let min_value: T = self.data.get(0)

        // Vector<T> has no remove(index) - only pop() (removes and
        // returns the last element). With one element left, that's the
        // root itself; otherwise move the last element to the root first,
        // then pop() the now-duplicated last slot off before bubbling down.
        if self.data.len() == 1 {
            self.data.pop()
        } else {
            self.data.set(0, self.data.get(self.data.len() - 1))
            self.data.pop()
            self.bubble_down(0)
        }

        result.set_ok(min_value)
        return result
    }

    // Peek at minimum element without removing
    func peek_min() -> Result<T, char*> {
        let result: Result<T, char*> = new Result<T, char*>()

        if self.is_empty() {
            result.set_err("Heap is empty")
            return result
        }

        result.set_ok(self.data.get(0))
        return result
    }

    // Clear the heap
    func clear() {
        self.data = new Vector<T>()
    }

    // Build heap from vector (heapify)
    func heapify(values: Vector<T>) {
        self.data = values

        let size: i64 = self.data.len()
        // Start from last non-leaf node and bubble down
        for let i: i64 = (size / 2) - 1, i >= 0, i = i - 1 {
            self.bubble_down(i)
        }
    }
}

// Priority Queue with custom priority values
class PriorityQueueItem<T> {
    let value: T
    let priority: i64

    constructor(val: T, pri: i64) {
        self.value = val
        self.priority = pri
    }

    // A class needs an explicit destructor - even an empty one - for any
    // *other* class's auto-generated cleanup to be able to release a
    // field of this type (see e.g. std.json.JsonValue's identical
    // comment): PriorityQueue<T>.dequeue()'s own Result<PriorityQueueItem<T>,
    // char*> needs PriorityQueueItem_destroy to exist at all.
    destructor() {}

    func operator<(other: PriorityQueueItem<T>) -> bool {
        return self.priority < other.priority
    }
}

class PriorityQueue<T> {
    let heap: BinaryHeap<PriorityQueueItem<T>>

    constructor() {
        self.heap = new BinaryHeap<PriorityQueueItem<T>>()
    }

    func enqueue(value: T, priority: i64) {
        let item: PriorityQueueItem<T> = new PriorityQueueItem<T>(value, priority)
        self.heap.insert(item)
    }

    func dequeue() -> Result<T, char*> {
        let result: Result<T, char*> = new Result<T, char*>()
        let item_result: Result<PriorityQueueItem<T>, char*> = self.heap.extract_min()

        if !item_result.is_ok() {
            result.set_err("Queue is empty")
            return result
        }

        let item: PriorityQueueItem<T> = item_result.unwrap()
        result.set_ok(item.value)
        return result
    }

    func peek() -> Result<T, char*> {
        let result: Result<T, char*> = new Result<T, char*>()
        let item_result: Result<PriorityQueueItem<T>, char*> = self.heap.peek_min()

        if !item_result.is_ok() {
            result.set_err("Queue is empty")
            return result
        }

        let item: PriorityQueueItem<T> = item_result.unwrap()
        result.set_ok(item.value)
        return result
    }

    func size() -> i64 {
        return self.heap.size()
    }

    func is_empty() -> bool {
        return self.heap.is_empty()
    }

    func clear() {
        self.heap.clear()
    }
}

// Max-heap (for convenience)
class MaxHeap<T> {
    let min_heap: BinaryHeap<T>

    constructor() {
        self.min_heap = new BinaryHeap<T>()
    }

    func insert(value: T) {
        // Negate value for max-heap behavior
        self.min_heap.insert(-value)
    }

    func extract_max() -> Result<T, char*> {
        let result: Result<T, char*> = self.min_heap.extract_min()
        if result.is_ok() {
            let val: T = result.unwrap()
            result.set_ok(-val)
        }
        return result
    }

    func peek_max() -> Result<T, char*> {
        let result: Result<T, char*> = self.min_heap.peek_min()
        if result.is_ok() {
            let val: T = result.unwrap()
            result.set_ok(-val)
        }
        return result
    }

    func size() -> i64 {
        return self.min_heap.size()
    }

    func is_empty() -> bool {
        return self.min_heap.is_empty()
    }

    func clear() {
        self.min_heap.clear()
    }
}

} // namespace collections
} // namespace std
