// Standard library: Enhanced HashMap
// Namespace: std::collections
// Note: prelude.llpl has a basic HashMap, this is an enhanced version with more features

namespace std {
namespace collections {

// Hash map entry
class HashMapEntry<K, V> {
    let key: K
    let value: V
    let hash: u64
    let next: HashMapEntry<K, V>*

    constructor(k: K, v: V, h: u64) {
        self.key = k
        self.value = v
        self.hash = h
        self.next = null
    }
}

// Enhanced HashMap with chaining for collision resolution
// Requires K to implement Hashable trait
class EnhancedHashMap<K: Hashable, V> {
    let buckets: HashMapEntry<K, V>**
    let capacity: i64
    let count: i64
    let load_factor: i64  // Percentage (e.g., 75 for 0.75)

    constructor() {
        self.capacity = 16
        self.count = 0
        self.load_factor = 75
        self.buckets = llpl_alloc(self.capacity * sizeof(HashMapEntry<K, V>*)) as HashMapEntry<K, V>**

        for let i: i64 = 0, i < self.capacity, i = i + 1 {
            self.buckets[i] = null
        }
    }

    constructor(initial_capacity: i64) {
        self.capacity = initial_capacity
        self.count = 0
        self.load_factor = 75
        self.buckets = llpl_alloc(self.capacity * sizeof(HashMapEntry<K, V>*)) as HashMapEntry<K, V>**

        for let i: i64 = 0, i < self.capacity, i = i + 1 {
            self.buckets[i] = null
        }
    }

    destructor() {
        self.clear()
        if self.buckets != null {
            llpl_free(self.buckets as u8*)
        }
    }

    func size() -> i64 {
        return self.count
    }

    func is_empty() -> bool {
        return self.count == 0
    }

    func get_bucket_index(hash: u64) -> i64 {
        // Modulo in unsigned arithmetic, THEN cast to i64 - casting the
        // (up to 64-bit) hash to i64 *before* the modulo reinterprets any
        // hash with its high bit set as a negative value, producing a
        // negative (out-of-bounds) bucket index and a segfault on
        // self.buckets[bucket_idx] - this bit real, depends only on the
        // hashed content, not on map size (e.g. FNV-1a of "cherry" hits
        // it; "apple"/"banana" happen not to). The result of `hash %
        // capacity` is always in [0, capacity), so casting *after* is safe.
        return (hash % (self.capacity as u64)) as i64
    }

    func should_resize() -> bool {
        return (self.count * 100) / self.capacity > self.load_factor
    }

    func resize() {
        let old_capacity: i64 = self.capacity
        let old_buckets: HashMapEntry<K, V>** = self.buckets

        self.capacity = self.capacity * 2
        self.buckets = llpl_alloc(self.capacity * sizeof(HashMapEntry<K, V>*)) as HashMapEntry<K, V>**

        for let i: i64 = 0, i < self.capacity, i = i + 1 {
            self.buckets[i] = null
        }

        self.count = 0

        // Rehash all entries
        for let i: i64 = 0, i < old_capacity, i = i + 1 {
            let entry: HashMapEntry<K, V>* = old_buckets[i]

            while entry != null {
                let next: HashMapEntry<K, V>* = (*entry).next
                self.insert((*entry).key, (*entry).value)
                llpl_free(entry as u8*)
                entry = next
            }
        }

        llpl_free(old_buckets as u8*)
    }

    func insert(key: K, value: V) {
        let hash: u64 = key.hash()
        let bucket_idx: i64 = self.get_bucket_index(hash)

        let entry: HashMapEntry<K, V>* = self.buckets[bucket_idx]

        // Check if key already exists
        while entry != null {
            if (*entry).hash == hash && (*entry).key.equals(key) {
                (*entry).value = value
                return
            }
            entry = (*entry).next
        }

        // Create new entry - a raw malloc'd node, not `new
        // HashMapEntry<K, V>(...)`: that would be a heap-allocated,
        // ref-counted *class* instance living at its own separate
        // address, and assigning it into `*new_entry` (this manually-
        // managed node's own storage) would just copy its ref-counted
        // struct bytes - including its hidden RefCount header - over
        // whatever llpl_alloc returned. This map frees entries by hand
        // (see clear()/remove()'s own llpl_free()), so initialize every
        // field directly instead.
        let new_entry: HashMapEntry<K, V>* = llpl_alloc(sizeof(HashMapEntry<K, V>)) as HashMapEntry<K, V>*
        (*new_entry).key = key
        (*new_entry).value = value
        (*new_entry).hash = hash

        (*new_entry).next = self.buckets[bucket_idx]
        self.buckets[bucket_idx] = new_entry
        self.count = self.count + 1

        if self.should_resize() {
            self.resize()
        }
    }

    func get(key: K) -> Result<V, u8*> {
        let result: Result<V, u8*> = new Result<V, u8*>()
        let hash: u64 = key.hash()
        let bucket_idx: i64 = self.get_bucket_index(hash)

        let entry: HashMapEntry<K, V>* = self.buckets[bucket_idx]

        while entry != null {
            if (*entry).hash == hash && (*entry).key.equals(key) {
                result.set_ok((*entry).value)
                return result
            }
            entry = (*entry).next
        }

        result.set_err("Key not found")
        return result
    }

    func contains(key: K) -> bool {
        let hash: u64 = key.hash()
        let bucket_idx: i64 = self.get_bucket_index(hash)

        let entry: HashMapEntry<K, V>* = self.buckets[bucket_idx]

        while entry != null {
            if (*entry).hash == hash && (*entry).key.equals(key) {
                return true
            }
            entry = (*entry).next
        }

        return false
    }

    func remove(key: K) -> Result<V, u8*> {
        let result: Result<V, u8*> = new Result<V, u8*>()
        let hash: u64 = key.hash()
        let bucket_idx: i64 = self.get_bucket_index(hash)

        let entry: HashMapEntry<K, V>* = self.buckets[bucket_idx]
        let prev: HashMapEntry<K, V>* = null

        while entry != null {
            if (*entry).hash == hash && (*entry).key.equals(key) {
                let value: V = (*entry).value

                if prev == null {
                    self.buckets[bucket_idx] = (*entry).next
                } else {
                    (*prev).next = (*entry).next
                }

                llpl_free(entry as u8*)
                self.count = self.count - 1

                result.set_ok(value)
                return result
            }

            prev = entry
            entry = (*entry).next
        }

        result.set_err("Key not found")
        return result
    }

    func keys() -> Vector<K> {
        let result: Vector<K> = new Vector<K>()

        for let i: i64 = 0, i < self.capacity, i = i + 1 {
            let entry: HashMapEntry<K, V>* = self.buckets[i]

            while entry != null {
                result.push((*entry).key)
                entry = (*entry).next
            }
        }

        return result
    }

    func values() -> Vector<V> {
        let result: Vector<V> = new Vector<V>()

        for let i: i64 = 0, i < self.capacity, i = i + 1 {
            let entry: HashMapEntry<K, V>* = self.buckets[i]

            while entry != null {
                result.push((*entry).value)
                entry = (*entry).next
            }
        }

        return result
    }

    func clear() {
        for let i: i64 = 0, i < self.capacity, i = i + 1 {
            let entry: HashMapEntry<K, V>* = self.buckets[i]

            while entry != null {
                let next: HashMapEntry<K, V>* = (*entry).next
                llpl_free(entry as u8*)
                entry = next
            }

            self.buckets[i] = null
        }

        self.count = 0
    }

    // Get load factor as percentage
    func get_load_factor() -> i64 {
        if self.capacity == 0 {
            return 0
        }
        return (self.count * 100) / self.capacity
    }

    // Get number of collisions (for performance analysis)
    func get_collision_count() -> i64 {
        let collisions: i64 = 0

        for let i: i64 = 0, i < self.capacity, i = i + 1 {
            let entry: HashMapEntry<K, V>* = self.buckets[i]
            let chain_length: i64 = 0

            while entry != null {
                chain_length = chain_length + 1
                entry = (*entry).next
            }

            if chain_length > 1 {
                collisions = collisions + (chain_length - 1)
            }
        }

        return collisions
    }
}

// HashSet - set of unique values
class HashSet<T: Hashable> {
    let map: EnhancedHashMap<T, bool>

    constructor() {
        self.map = new EnhancedHashMap<T, bool>()
    }

    func insert(value: T) {
        self.map.insert(value, true)
    }

    func contains(value: T) -> bool {
        return self.map.contains(value)
    }

    func remove(value: T) -> bool {
        let result: Result<bool, u8*> = self.map.remove(value)
        return result.is_ok()
    }

    func size() -> i64 {
        return self.map.size()
    }

    func is_empty() -> bool {
        return self.map.is_empty()
    }

    func clear() {
        self.map.clear()
    }

    func to_vector() -> Vector<T> {
        return self.map.keys()
    }

    // Set operations
    // Named union_with, not union - `union` is a reserved keyword (see
    // ast.d's UnionDecl/the `union` type feature).
    func union_with(other: HashSet<T>) -> HashSet<T> {
        let result: HashSet<T> = new HashSet<T>()

        let this_items: Vector<T> = self.to_vector()
        for let i: i64 = 0, i < this_items.len(), i = i + 1 {
            result.insert(this_items.get(i))
        }

        let other_items: Vector<T> = other.to_vector()
        for let i: i64 = 0, i < other_items.len(), i = i + 1 {
            result.insert(other_items.get(i))
        }

        return result
    }

    func intersection(other: HashSet<T>) -> HashSet<T> {
        let result: HashSet<T> = new HashSet<T>()

        let this_items: Vector<T> = self.to_vector()
        for let i: i64 = 0, i < this_items.len(), i = i + 1 {
            let item: T = this_items.get(i)
            if other.contains(item) {
                result.insert(item)
            }
        }

        return result
    }

    func difference(other: HashSet<T>) -> HashSet<T> {
        let result: HashSet<T> = new HashSet<T>()

        let this_items: Vector<T> = self.to_vector()
        for let i: i64 = 0, i < this_items.len(), i = i + 1 {
            let item: T = this_items.get(i)
            if !other.contains(item) {
                result.insert(item)
            }
        }

        return result
    }
}

} // namespace collections
} // namespace std
