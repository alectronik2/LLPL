// LLPL Standard Library
// Main entry point for importing all stdlib modules

// Import all standard library modules
import "io/file.llpl"
import "net/socket.llpl"
import "text/string_utils.llpl"
import "collections/collections.llpl"
import "sdl/sdl.llpl"
import "args/args_parser.llpl"
import "yaml/yaml_parser.llpl"
import "json/json_parser.llpl"

// Re-export commonly used aliass and functions for convenience
namespace std {
    // Convenient alias aliases
    alias File = io.File
    alias Socket = net.Socket
    alias TcpServer = net.TcpServer
    alias TcpClient = net.TcpClient
    alias UdpSocket = net.UdpSocket
    alias SockAddrIn = net.SockAddrIn
    alias StringBuilder = text.StringBuilder
    alias StringUtils = text.StringUtils
    alias CharUtils = text.CharUtils
    alias Format = text.Format
    alias ArgParser = args.ArgParser
    alias ArgOption = args.ArgOption
    alias YamlValue = yaml.YamlValue
    alias JsonValue = json.JsonValue

    // Collection alias aliases
    alias LinkedList = collections.LinkedList
    alias DoublyLinkedList = collections.DoublyLinkedList
    alias Stack = collections.Stack
    alias Queue = collections.Queue
    alias Deque = collections.Deque
    alias CircularBuffer = collections.CircularBuffer
    alias RBTree = collections.RBTree
    alias BinaryHeap = collections.BinaryHeap
    alias MaxHeap = collections.MaxHeap
    alias PriorityQueue = collections.PriorityQueue
    alias EnhancedHashMap = collections.EnhancedHashMap
    alias HashSet = collections.HashSet
    alias Trie = collections.Trie
    alias Graph = collections.Graph
    alias GraphMatrix = collections.GraphMatrix
    alias Edge = collections.Edge

    // Commonly used constants
    namespace io_const {
        const O_RDONLY: int = io.O_RDONLY
        const O_WRONLY: int = io.O_WRONLY
        const O_RDWR: int = io.O_RDWR
        const O_CREAT: int = io.O_CREAT
        const O_TRUNC: int = io.O_TRUNC
        const O_APPEND: int = io.O_APPEND
    }

    namespace net_const {
        const AF_INET: int = net.AF_INET
        const SOCK_STREAM: int = net.SOCK_STREAM
        const SOCK_DGRAM: int = net.SOCK_DGRAM
        const IPPROTO_TCP: int = net.IPPROTO_TCP
        const IPPROTO_UDP: int = net.IPPROTO_UDP
    }
}

