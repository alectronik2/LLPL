// Network I/O example - TCP Server
func example_tcp_server() {
    let server: std.TcpServer = new std.TcpServer(8080)
    let start_result: Result<bool, char*> = server.start(10)

    if start_result.is_ok() {
        for true {  // infinite loop
            let client_result: Result<std.Socket, char*> = server.accept()
            if client_result.is_ok() {
                let client: std.Socket = client_result.unwrap()
                let recv_result: Result<String, char*> = client.recv_string(1024)

                if recv_result.is_ok() {
                    let message: String = recv_result.unwrap()
                    client.send_string(new String("Echo: ") + message)
                }
            }
        }
    }
}

// Network I/O example - TCP Client
func example_tcp_client() {
    let client: std.TcpClient = new std.TcpClient()
    let connect_result: Result<bool, char*> = client.connect(127, 0, 0, 1, 8080)

    if connect_result.is_ok() {
        client.send(new String("Hello, Server!"))
        let response: Result<String, char*> = client.recv(1024)

        if response.is_ok() {
            let msg: String = response.unwrap()
            // Process message...
        }

        client.close()
    }
}

// String utilities example
func example_string_utils() {
    let s: String = new String("  Hello, World!  ")

    // Trim
    let trimmed: String = std.StringUtils.trim(s)

    // Split
    let parts: Vector<String> = std.StringUtils.split(trimmed, ',')

    // Join
    let joined: String = std.StringUtils.join(parts, new String(" | "))

    // Case conversion
    let upper: String = std.StringUtils.to_upper(joined)
    let lower: String = std.StringUtils.to_lower(upper)

    // Search
    let idx: int = std.StringUtils.index_of(s, new String("World"))
    let contains: bool = std.StringUtils.contains(s, new String("Hello"))

    // Replace
    let replaced: String = std.StringUtils.replace_all(s, new String("World"), new String("LLPL"))
}

// StringBuilder example
func example_string_builder() {
    let sb: std.StringBuilder = new std.StringBuilder()

    sb.append(new String("Hello"))
    sb.append_char(' ')
    sb.append(new String("from"))
    sb.append_char(' ')
    sb.append(new String("LLPL"))
    sb.append_char('!')

    sb.append_char('\n')
    sb.append(new String("Number: "))
    sb.append_int(42)

    let result: String = sb.to_string()
    // "Hello from LLPL!\nNumber: 42"
}

