extern func puts(s: string) -> int

struct List<T> {
    let head: T
    let tail: List<T>*
}

class Klass {
    i: int

    constructor() {
        puts("Klass constructor")
    }

    constructor( s: string ) {
        puts("Klass constructor with string: \(s)")
        self.i = 10
    }

    destructor() {
        puts("Klass destructor")
    }

    func stringof() -> string {
        "Overridden: Klass"
    }
}

impl Iterator for Klass {
    func iter_has_next() -> bool {
        return self.i> 0
    }
    func iter_next() -> int {
        self.i = self.i- 1
        return self.i + 1
    }
}

func dbl( first: string, second: string = "world") -> (string, string) {
    (first, second)
}

func pointer_to_pointer() {
    let x: int = 5
    let p: int* = &x
    let pp: int** = &p
    puts("Before: *p = \( *p ), **pp = \( **pp )")
}

func throw_func() {
    throw "This is a test exception"
}

func throw_func( l: int ) {
    throw "This is another test exception \(l)"
}

trait Foo {
    func foo() -> int 
}

impl Foo for Klass {
    func foo() -> int {
        42
    }
}

namespace Foo {
    namespace Bar {
        func bar() -> int {
            99
        }
    }
}

func main() -> uint32 {
    "123" |> puts() unless false

    let x = if true {
        "Working"
    } else {
        "Not working"
    }
    "x = \(x)" |> puts()

    let (a, b) = dbl( first: "hello" )
    "a = \(a), b = \(b)" |> puts()

    let l: List<int> 
    l.head = 1
    l.tail = null

    let xx = 666
    let inner = func[xx]( l: int ) -> int {
        xx + 1 + l
    }
    let result = inner( 6 )
    puts("result = \(result)")

    let res = /[a-z]+/.captures("f")
    puts("res = \(res)")

    let k = new Klass()
    puts("k = \(k) is of size \(k.sizeof)")
    delete k

    try {
        throw_func(22)
    } catch error: string {
        puts("Caught an exception: \(error)")
    } finally {
        puts("Finally block executed")
    }

    pointer_to_pointer()

    let to = 5
    for i in 0..to {
        puts("i = \(i)")
    }

    let kl = new Klass("With a string")

    puts("kl.foo = \(kl.foo() as uint)")

    for x in kl {
        puts("x = \(x)")
    }

    let ss = "Hello, world!"
    match ss {
        case "Hello, world!" => { puts("Matched the string!") }
        case _ => { puts("Did not match the string.")   }
    }

    let sug = 88 as uint
    //puts( "Sug.foo is \(sug.foo)" )

    result
}