extern func puts(s: string) -> i64

struct List<T> {
    let head: T
    let tail: List<T>*
}

class Parent {
    func as_string() -> string {
        "Parent as_string"
    }

    constructor() {
        puts("Parent constructor")
    }

    destructor() {
        puts("Parent destructor")
    }
}

class Klass: Parent {
    i: i64

    constructor() {
        puts("Klass constructor")
    }

    constructor( s: string ) {
        super()
        puts("Klass constructor with string: \(s)")
        self.i = 10
    }

    destructor() {
        puts("Klass destructor")
    }


    func as_string() -> string {
        "Overridden: Klass as_string"
    }
}

impl Iterator for Klass {
    func iter_has_next() -> bool {
        return self.i> 0
    }
    func iter_next() -> i64 {
        self.i = self.i- 1
        return self.i + 1
    }
}

func dbl( first: string, second: string = "world") -> (string, string) {
    (first, second)
}

func pointer_to_pointer() {
    let x: i64 = 5
    let p: i64* = &x
    let pp: i64** = &p
    "Before: *p = \( *p ), **pp = \( **pp )" |> puts()
}

func throw_func() {
    throw "This is a test exception"
}

func throw_func( l: i64 ) {
    throw "This is another test exception \(l)"
}

trait Foo {
    func foo() -> i64 
}

impl Foo for Klass {
    func foo() -> i64 {
        42
    }
}

namespace Foo {
    namespace Bar {
        func bar() -> i64 {
            99
        }
    }
}

func xy() -> i32 {
    return 1
}

func main( args: string[] ) -> u32 {
    "123" |> puts() unless false

    let x = if true {
        "Working"
    } else {
        "Not working"
    }
    "x = \(x)" |> puts()

    let (a, b) = dbl( first: "hello" )
    "a = \(a), b = \(b)" |> puts()

    let l: List<i64> 
    l.head = 1
    l.tail = null

    let xx = 666
    let inner = func[xx]( l: i64 ) -> i64 {
        xx + 1 + l
    }
    let result = inner( 6 )
    puts("result = \(result)")

    let res = /[a-z]+/.captures("f")
    puts("res = \(res)")

    let k = new Klass()
    puts("k = \(k) is of size \(k.sizeof)")
    delete k

    try {
        throw_func(22)
    } catch error: string {
        puts("Caught an exception: \(error)")
    } finally {
        puts("Finally block executed")
    }

    pointer_to_pointer()

    let to = 5
    for i in 0..to {
        "i = \(i)" |> puts()
    }

    let kl = new Klass("With a string")
    let sz: string = kl
    puts("sz = \(sz)")
    "kl as string implicitly: \(kl)" |> puts()

    puts("kl.foo = \(kl.foo() as u64)")

    for x in kl {
        "x = \(x)" |> puts()
    }

    let ss = "Hello, world!"
    match ss {
        case "Hello, world!" => { puts("Matched the string!") }
        case _ => { puts("Did not match the string.")   }
    }

    let sug = 88 as u64
    //puts( "Sug.foo is \(sug.foo)" )

    for arg in args {
        "arg = \(arg)" |> puts()
    }

    delete kl

    assert( false )

    xy()
}