extern func puts(s: string) -> int

struct List<T> {
    let head: T
    let tail: List<T>*
}

func dbl( first: string, second: string = "world") -> (string, string) {
    (first, second)
}

func main() -> int {
    "123" |> puts() unless false

    let x = if true {
        "Working"
    } else {
        "Not working"
    }
    "x = \(x)" |> puts()

    let (a, b) = dbl( "hello", "world" )
    "a = \(a), b = \(b)" |> puts()

    let l: List<int> 

    let xx = 666
    let inner = func[xx]( l: int ) -> int {
        xx + 1 + l
    }
    let result = inner( 6 )
    puts("result = \(result)")

    result
}