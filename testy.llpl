extern func puts(s: string) -> int

struct List<T> {
    let head: T
    let tail: List<T>*
}

class Klass {
    constructor() {
        puts("Klass constructor")
    }

    destructor() {
        puts("Klass destructor")
    }

    func stringof() -> string {
        "Overridden: Klass"
    }
}

func dbl( first: string, second: string = "world") -> (string, string) {
    (first, second)
}

func main() -> int {
    "123" |> puts() unless false

    let x = if true {
        "Working"
    } else {
        "Not working"
    }
    "x = \(x)" |> puts()

    let (a, b) = dbl( first: "hello" )
    "a = \(a), b = \(b)" |> puts()

    let l: List<int> 
    l.head = 1
    l.tail = null

    let xx = 666
    let inner = func[xx]( l: int ) -> int {
        xx + 1 + l
    }
    let result = inner( 6 )
    puts("result = \(result)")

    let res = /[a-z]+/.captures("f")
    puts("res = \(res.stringof)")

    let k = new Klass()
    puts("k = \(k.stringof)")

    result
}