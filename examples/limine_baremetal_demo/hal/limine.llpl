packed struct LimineFramebuffer {
    let address: u64
    let width: u64
    let height: u64
    let pitch: u64
    let bpp: uint16
    let memory_model: u8
    let red_mask_size: u8
    let red_mask_shift: u8
    let green_mask_size: u8
    let green_mask_shift: u8
    let blue_mask_size: u8
    let blue_mask_shift: u8
    let unused: u8[7]
    let edid_size: u64
    let edid: u64
    let mode_count: u64
    let modes: u64
}

packed struct LimineFramebufferRequest {
    let id: u64[4]
    let revision: u64
    let response: LimineFramebufferResponse*
}

packed struct LimineFramebufferResponse {
    let revision: u64
    let framebuffer_count: u64
    let framebuffers: u64*
}

packed struct LimineMemmapEntry {
    let base: u64
    let length: u64
    let entry_type: u64
}

packed struct LimineMemmapRequest {
    let id: u64[4]
    let revision: u64
    let response: LimineMemmapResponse*
}

packed struct LimineMemmapResponse {
    let revision: u64
    let entry_count: u64
    let entries: u64
}

packed struct LimineHhdmRequest {
    let id: u64[4]
    let revision: u64
    let response: LimineHhdmResponse*
}

packed struct LimineHhdmResponse {
    let revision: u64
    let offset: u64
}

// Limine's fixed protocol magic numbers - see the Limine boot protocol
// spec's "Requests" section. `alias NAME = [ ... ]` names an array
// literal at compile time only (never its own addressable symbol); each
// use below is expanded back into these same values, either as a whole
// initializer or spliced into a larger array literal it's one element of
// (see codegen.d's arrayLiteralAliases).
alias limine_start_marker_id = [
    0xf6b8f4b39de7d1ae,
    0xfab91a6940fcb9cf,
    0x785c6ed015d3e316,
    0x181e920a7852b9d9
]

alias limine_end_marker_id = [
    0xadc0e0531bb10d03,
    0x9572709f31764c62
]

// Common to every request's `id` field - the first two of its four
// words never change, only the last two (request-specific) do.
alias limine_common_magic = [
    0xc7b1dd30df4c8b88,
    0x0a82e883a194f07b
]

alias limine_framebuffer_request_id = [
    limine_common_magic,
    0x9d5827dcd881dd75,
    0xa3148604f6fab11b
]

alias limine_memmap_request_id = [
    limine_common_magic,
    0x67cf3d9d378a806f,
    0xe304acdfc50c3c62
]

alias limine_hhdm_request_id = [
    limine_common_magic,
    0x48dcf1cb8ad2b852,
    0x63984e959a98244b
]

enum MemMapType: u64 {
    Usable = 0,
    Reserved = 1,
    AcpiReclaimable = 2,
    AcpiNvs = 3,
    BadMemory = 4,
    BootloaderReclaimable = 5,
    ExecutableAndModules = 6,
    Framebuffer = 7,
    ReservedMapped = 8,
}

