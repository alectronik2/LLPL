// Minimal test kernel - no allocations

let VGA_BUFFER: uint = 753664  // 0xB8000

func write_string(buffer: char*, str: char*, offset: int) {
    let i: int = 0
    while str[i] != 0 {
        buffer[offset + i * 2] = str[i]
        buffer[offset + i * 2 + 1] = 15  // White on black
        i = i + 1
    }
}

func kernel_main() {
    let buffer: char* = VGA_BUFFER as char*

    // Clear screen
    for let i: int = 0, i < 80 * 25 * 2, i = i + 2 {
        buffer[i] = 0
        buffer[i + 1] = 15
    }

    // Write test messages
    write_string(buffer, "LLPL 64-bit Test\n", 0)
    write_string(buffer, "Boot successful!", 160)  // Second line

    // Infinite loop
    while true {
        // Hang
    }
}
