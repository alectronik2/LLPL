        0, 0, 0, 0, 6, 14, 56, 96, 96, 56, 14, 6, 0, 0, 0, 0, // 60 '<'
        0, 0, 0, 0, 0, 0, 126, 0, 0, 126, 0, 0, 0, 0, 0, 0, // 61 '='
        0, 0, 0, 0, 96, 112, 28, 6, 6, 28, 112, 96, 0, 0, 0, 0, // 62 '>'
        0, 0, 24, 126, 102, 6, 6, 12, 24, 24, 0, 24, 24, 0, 0, 0, // 63 '?'
        0, 0, 60, 102, 195, 219, 219, 219, 219, 219, 222, 204, 96, 62, 0, 0, // 64 '@'
        0, 0, 0, 24, 24, 60, 60, 36, 36, 126, 102, 66, 66, 0, 0, 0, // 65 'A'
        0, 0, 120, 124, 70, 70, 102, 124, 102, 66, 66, 126, 124, 0, 0, 0, // 66 'B'
        0, 0, 24, 126, 102, 64, 64, 64, 64, 64, 66, 126, 60, 0, 0, 0, // 67 'C'
        0, 0, 112, 124, 70, 70, 66, 66, 66, 102, 70, 124, 120, 0, 0, 0, // 68 'D'
        0, 0, 62, 126, 96, 96, 96, 124, 96, 96, 96, 126, 126, 0, 0, 0, // 69 'E'
        0, 0, 62, 126, 96, 96, 96, 60, 96, 96, 96, 96, 32, 0, 0, 0, // 70 'F'
