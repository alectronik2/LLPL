        0, 0, 0, 0, 0, 0, 0, 50, 126, 76, 0, 0, 0, 0, 0, 0 // 126 '~'
    ]

    const GLYPH_WIDTH = 8
    const GLYPH_HEIGHT = 16

    // Draws one u8acter at pixel position (x, y). Anything outside the
    // printable ASCII range (32-126) draws as a blank cell rather than
    // garbage - there's no glyph data for it.
    func draw_u8(x: u32, y: u32, c: u8, fg: u32, bg: u32) {
        let code: int = c as int
        if code < 32 || code > 126 {
            code = 32
        }
        let glyph_offset: int = (code - 32) * GLYPH_HEIGHT

        let row: int = 0
        while row < GLYPH_HEIGHT {
            // `& 255` undoes u8's signedness before testing bits - a
            // glyph row byte like 254 would otherwise read back negative
            // and corrupt every bit test below.
            let bits: int = (font_data[glyph_offset + row] as int) & 255
            let col: int = 0
            while col < GLYPH_WIDTH {
                let mask: int = 128 >> col
                if (bits & mask) != 0 {
                    put_pixel(x + (col as u32), y + (row as u32), fg)
                } else {
                    put_pixel(x + (col as u32), y + (row as u32), bg)
                }
                col = col + 1
            }
            row = row + 1
        }
    }

    func draw_string(x: u32, y: u32, str: u8*, fg: u32, bg: u32) {
        let i: int = 0
        let cur_x: u32 = x
        while str[i] != 0 {
            draw_u8(cur_x, y, str[i], fg, bg)
            cur_x = cur_x + (GLYPH_WIDTH as u32)
            i = i + 1
        }
    }
}
