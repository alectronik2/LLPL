// Embedded TrueType-style font data
// For demonstration, we'll create a simple vector font programmatically

import "../libsys/imports"

// Simple vector font: define glyphs as line segments
struct VectorGlyph {
    let advance_width: i16
    let x_min: i16
    let y_min: i16
    let x_max: i16
    let y_max: i16
    // Simple representation: alternating x,y coordinates of line endpoints
    let points: i16[32]
    let num_points: u16
}

// Create a simple vector 'A'
func create_glyph_A() -> VectorGlyph {
    let glyph: VectorGlyph
    glyph.advance_width = 600
    glyph.x_min = 0
    glyph.y_min = 0
    glyph.x_max = 600
    glyph.y_max = 700

    // Define 'A' shape as line segments
    // Left leg: (100, 0) to (250, 700)
    glyph.points[0] = 100
    glyph.points[1] = 0
    glyph.points[2] = 250
    glyph.points[3] = 700

    // Right leg: (500, 0) to (350, 700)
    glyph.points[4] = 500
    glyph.points[5] = 0
    glyph.points[6] = 350
    glyph.points[7] = 700

    // Top: (250, 700) to (350, 700)
    glyph.points[8] = 250
    glyph.points[9] = 700
    glyph.points[10] = 350
    glyph.points[11] = 700

    // Crossbar: (200, 250) to (400, 250)
    glyph.points[12] = 200
    glyph.points[13] = 250
    glyph.points[14] = 400
    glyph.points[15] = 250

    glyph.num_points = 8  // 4 lines = 8 points

    return glyph
}

// Render a vector glyph using line drawing
func render_vector_glyph(glyph: VectorGlyph, scale: i16, baseline: i16,
                         buffer: u8*, buf_w: i16, buf_h: i16, x_offset: i16) {
    let i: u16 = 0
    while i + 3 < glyph.num_points * 2 {
        let x1: i16 = (glyph.points[i] * scale / 1000) + x_offset
        let y1: i16 = baseline - (glyph.points[i + 1] * scale / 1000)
        let x2: i16 = (glyph.points[i + 2] * scale / 1000) + x_offset
        let y2: i16 = baseline - (glyph.points[i + 3] * scale / 1000)

        // Simple line drawing (Bresenham's algorithm)
        draw_line(buffer, buf_w, buf_h, x1, y1, x2, y2)

        i = i + 4
    }
}

// Bresenham's line algorithm
func draw_line(buffer: u8*, buf_w: i16, buf_h: i16,
               x0: i16, y0: i16, x1: i16, y1: i16) {
    let dx: i16 = x1 - x0
    let dy: i16 = y1 - y0

    if dx < 0 { dx = -dx }
    if dy < 0 { dy = -dy }

    let sx: i16 = -1
    if x0 < x1 { sx = 1 }

    let sy: i16 = -1
    if y0 < y1 { sy = 1 }

    let err: i16 = dx - dy
    let x: i16 = x0
    let y: i16 = y0

    let max_steps: i64 = 1000  // Prevent infinite loops
    let steps: i64 = 0

    while steps < max_steps {
        if x >= 0 && x < buf_w && y >= 0 && y < buf_h {
            buffer[(y as u32) * (buf_w as u32) + (x as u32)] = 255
        }

        if x == x1 && y == y1 {
            return
        }

        let e2: i16 = err * 2

        if e2 > -dy {
            err = err - dy
            x = x + sx
        }

        if e2 < dx {
            err = err + dx
            y = y + sy
        }

        steps = steps + 1
    }
}

// Create additional vector glyphs
func create_glyph_H() -> VectorGlyph {
    let glyph: VectorGlyph
    glyph.advance_width = 600
    glyph.x_min = 50
    glyph.y_min = 0
    glyph.x_max = 550
    glyph.y_max = 700

    // Left vertical: (100, 0) to (100, 700)
    glyph.points[0] = 100
    glyph.points[1] = 0
    glyph.points[2] = 100
    glyph.points[3] = 700

    // Right vertical: (500, 0) to (500, 700)
    glyph.points[4] = 500
    glyph.points[5] = 0
    glyph.points[6] = 500
    glyph.points[7] = 700

    // Crossbar: (100, 350) to (500, 350)
    glyph.points[8] = 100
    glyph.points[9] = 350
    glyph.points[10] = 500
    glyph.points[11] = 350

    glyph.num_points = 6

    return glyph
}

