func create_glyph_O() -> VectorGlyph {
    let glyph: VectorGlyph
    glyph.advance_width = 650
    glyph.x_min = 100
    glyph.y_min = 0
    glyph.x_max = 550
    glyph.y_max = 700

    // Draw as octagon for simplicity
    // Top
    glyph.points[0] = 200
    glyph.points[1] = 700
    glyph.points[2] = 450
    glyph.points[3] = 700

    // Top-right
    glyph.points[4] = 450
    glyph.points[5] = 700
    glyph.points[6] = 550
    glyph.points[7] = 600

    // Right
    glyph.points[8] = 550
    glyph.points[9] = 600
    glyph.points[10] = 550
    glyph.points[11] = 100

    // Bottom-right
    glyph.points[12] = 550
    glyph.points[13] = 100
    glyph.points[14] = 450
    glyph.points[15] = 0

    // Bottom
    glyph.points[16] = 450
    glyph.points[17] = 0
    glyph.points[18] = 200
    glyph.points[19] = 0

    // Bottom-left
    glyph.points[20] = 200
    glyph.points[21] = 0
    glyph.points[22] = 100
    glyph.points[23] = 100

    // Left
    glyph.points[24] = 100
    glyph.points[25] = 100
    glyph.points[26] = 100
    glyph.points[27] = 600

    // Top-left
    glyph.points[28] = 100
    glyph.points[29] = 600
    glyph.points[30] = 200
    glyph.points[31] = 700

    glyph.num_points = 16

    return glyph
}

