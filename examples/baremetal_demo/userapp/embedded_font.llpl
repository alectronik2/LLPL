// Enhanced bitmap font rendering with anti-aliasing simulation
func render_smooth_char(c: char, size: i16, buffer: u8*, buf_w: i16, buf_h: i16) {
    // Clear buffer
    let i: i16 = 0
    while i < buf_w * buf_h {
        buffer[i] = 0
        i = i + 1
    }

    // Render based on character
    let rendered: bool = false
    let glyph: VectorGlyph

    if c == 65 || c == 97 {  // 'A' or 'a'
        glyph = create_glyph_A()
        rendered = true
    } else if c == 68 || c == 100 {  // 'D' or 'd'
        glyph = create_glyph_D()
        rendered = true
    } else if c == 69 || c == 101 {  // 'E' or 'e'
        glyph = create_glyph_E()
        rendered = true
    } else if c == 72 || c == 104 {  // 'H' or 'h'
        glyph = create_glyph_H()
        rendered = true
    } else if c == 73 || c == 105 {  // 'I' or 'i'
        glyph = create_glyph_I()
        rendered = true
    } else if c == 76 || c == 108 {  // 'L' or 'l'
        glyph = create_glyph_L()
        rendered = true
    } else if c == 77 || c == 109 {  // 'M' or 'm'
        glyph = create_glyph_M()
        rendered = true
    } else if c == 78 || c == 110 {  // 'N' or 'n'
        glyph = create_glyph_N()
        rendered = true
    } else if c == 79 || c == 111 {  // 'O' or 'o'
        glyph = create_glyph_O()
        rendered = true
    } else if c == 82 || c == 114 {  // 'R' or 'r'
        glyph = create_glyph_R()
        rendered = true
    } else if c == 83 || c == 115 {  // 'S' or 's'
        glyph = create_glyph_S()
        rendered = true
    } else if c == 84 || c == 116 {  // 'T' or 't'
        glyph = create_glyph_T()
        rendered = true
    }

    if rendered {
        render_vector_glyph(glyph, size, buf_h * 3 / 4, buffer, buf_w, buf_h, 0)
    }

    // For unsupported characters, draw a placeholder box
    if !rendered && c >= 32 {
        let box_w: i16 = size / 2
        let box_h: i16 = size
        let y: i16 = buf_h / 4
        let row: i16 = 0
        while row < box_h {
            buffer[((y + row) as u32) * (buf_w as u32)] = 255
            buffer[((y + row) as u32) * (buf_w as u32) + (box_w as u32)] = 255
            row = row + 1
        }
        let col: i16 = 0
        while col < box_w {
            buffer[((y as u32) * (buf_w as u32)) + (col as u32)] = 255
            buffer[(((y + box_h) as u32) * (buf_w as u32)) + (col as u32)] = 255
            col = col + 1
        }
    }
}

// Check if a character is supported by vector font
func is_vector_char(c: char) -> bool {
    if c == 65 || c == 97 { return true }  // A
    if c == 68 || c == 100 { return true }  // D
    if c == 69 || c == 101 { return true }  // E
    if c == 72 || c == 104 { return true }  // H
    if c == 73 || c == 105 { return true }  // I
    if c == 76 || c == 108 { return true }  // L
    if c == 77 || c == 109 { return true }  // M
    if c == 78 || c == 110 { return true }  // N
    if c == 79 || c == 111 { return true }  // O
    if c == 82 || c == 114 { return true }  // R
    if c == 83 || c == 115 { return true }  // S
    if c == 84 || c == 116 { return true }  // T
    return false
}

// Get approximate advance width for a character
func get_char_advance(c: char, size: i16) -> i16 {
    if c == 73 || c == 105 {  // I is narrower
        return size / 2
    } else if c == 77 || c == 109 {  // M is wider
        return size * 3 / 4
    } else if c == 32 {  // Space
        return size / 3
    }
    return size * 6 / 10  // Default advance
}

// Render smooth text to buffer with better quality than bitmap font
func render_smooth_text(text: char*, size: i16, buffer: u32*, buf_w: i16, buf_h: i16,
                        x: i16, y: i16, color: u32, bg_color: u32) {
    let char_buf: u8[1024]  // 32x32 character buffer (reduced to save stack)
    let char_w: i16 = 32
    let char_h: i16 = 32

    let cursor_x: i16 = x
    let i: i64 = 0

    while text[i] != 0 {
        let c: char = text[i]

        // Only render if supported, otherwise skip with spacing
        if is_vector_char(c) {
            // Render character to temp buffer
            render_smooth_char(c, size, char_buf as u8*, char_w, char_h)

            // Copy to main buffer with anti-aliasing
            let cy: i16 = 0
            while cy < char_h {
                let cx: i16 = 0
                while cx < char_w {
                    let alpha: u8 = char_buf[(cy as u32) * (char_w as u32) + (cx as u32)]

                    if alpha > 0 {
                        let px: i16 = cursor_x + cx
                        let py: i16 = y + cy

                        if px >= 0 && px < buf_w && py >= 0 && py < buf_h {
                            if alpha == 255 {
                                buffer[(py as u32) * (buf_w as u32) + (px as u32)] = color
                            } else {
                                // Blend with background for anti-aliasing
                                let r_fg: u32 = (color >> 16) & 0xFF
                                let g_fg: u32 = (color >> 8) & 0xFF
                                let b_fg: u32 = color & 0xFF

                                let r_bg: u32 = (bg_color >> 16) & 0xFF
                                let g_bg: u32 = (bg_color >> 8) & 0xFF
                                let b_bg: u32 = bg_color & 0xFF

                                let a: u32 = alpha as u32
                                let r: u32 = (r_fg * a + r_bg * (255 - a)) / 255
                                let g: u32 = (g_fg * a + g_bg * (255 - a)) / 255
                                let b: u32 = (b_fg * a + b_bg * (255 - a)) / 255

                                let blended: u32 = (r << 16) | (g << 8) | b
                                buffer[(py as u32) * (buf_w as u32) + (px as u32)] = blended
                            }
                        }
                    }

                    cx = cx + 1
                }
                cy = cy + 1
            }
        }

        // Advance cursor
        cursor_x = cursor_x + get_char_advance(c, size)
        i = i + 1
    }
}
