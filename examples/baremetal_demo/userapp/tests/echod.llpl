// Persistent named IPC service: registers as "echo" and answers requests
// forever. Unlike echoserver.llpl (a one-shot child spawned and owned by
// ipcdemo.llpl), nothing spawns this task's clients and it spawns none of
// them either - echoclient.llpl finds it purely by name via sys_lookup.

import "../../libsys/imports"
import "../user_runtime"

func upper_char(c: u8) -> u8 {
    if c >= 97 && c <= 122 {
        return c - 32
    }
    return c
}

func _start(argc: u64, argv: u64*) {
    if sys_register("echo") == RT_SYS_ERR {
        rt_exit(1)
    }

    while true {
        let buf: u8[64]
        let sender: u64 = sys_msg_recv(buf as u8*, 64)
        if sender == RT_SYS_ERR {
            continue
        }

        let i: u64 = 0
        while buf[i] != 0 && i < 63 {
            buf[i] = upper_char(buf[i])
            i = i + 1
        }
        sys_msg_reply(sender, buf as u8*, i + 1)
    }
}
