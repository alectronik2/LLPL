// Proves sys_shm_map shares real physical memory, not just a copy: reads
// the "shmsvc" page before poking the server (expects zero - untouched
// since sys_shm_create zeroes fresh pages), pokes it over a tiny IPC
// message well under the 128-byte cap, then reads the SAME local pointer
// again and expects the server's bulk payload to have appeared there -
// something only possible if both tasks are mapping the same physical page.

import "../../libsys/imports"
import "../user_runtime"

const BULK_LEN = 600

func _start(argc: u64, argv: u64*) {
    sys_putln("shmclient")

    let handle: u64 = RT_SYS_ERR
    let tries: u64 = 0
    while handle == RT_SYS_ERR && tries < 50 {
        handle = sys_lookup("shmsvc")
        if handle == RT_SYS_ERR {
            sys_yield()
        }
        tries = tries + 1
    }
    if handle == RT_SYS_ERR {
        sys_putln("shmclient lookup=fail")
        rt_exit(1)
    }

    let shm: u8* = sys_shm_map(handle)
    if shm == null {
        sys_putln("shmclient shm_map=fail")
        rt_exit(1)
    }

    if shm[0] == 0 {
        sys_putln("before-poke=zero")
    } else {
        sys_putln("before-poke=UNEXPECTED (bug!)")
    }

    // sys_msg_send's buffer gets overwritten in place with the reply once
    // it arrives, so it must be a real writable local, not a string literal
    // (see ipcdemo.llpl's same precaution).
    let poke: char[16]
    sys_strcpy(poke as char*, "poke")
    let n: u64 = sys_msg_send(handle, poke as u8*, 5)
    if n == RT_SYS_ERR {
        sys_putln("shmclient send=fail")
        rt_exit(1)
    }

    let ok: bool = true
    let i: u64 = 0
    while i < BULK_LEN {
        let expected: u8 = (65 + (i % 26)) as u8
        if shm[i] != expected {
            ok = false
        }
        i = i + 1
    }
    if ok && shm[BULK_LEN] == 0 {
        sys_putln("bulk-transfer=PASS")
    } else {
        sys_putln("bulk-transfer=FAIL")
    }

    rt_exit(0)
}
