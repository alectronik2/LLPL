// Dynamic LLPL spawn/wait smoke test.

import "../../libsys/imports"
import "../user_runtime"

func _start(argc: u64, argv: u64*) {
    sys_putln("spawnwait")
    let pid: u64 = sys_spawn("/bin/memtest.elf", "from-spawnwait")
    if pid == RT_SYS_ERR {
        sys_putln("spawnwait pid=fail")
        rt_exit(1)
    }

    let status: u64 = sys_wait(pid)
    if status == RT_SYS_ERR {
        sys_putln("wait=fail")
        rt_exit(1)
    }
    rt_put_uint_line("pid=", pid)
    rt_put_uint_line("wait=", status)
    rt_exit(0)
}
