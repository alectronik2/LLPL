// Windowing compositor demo, window 2 of 2 - see winball1.llpl's own doc
// comment for what this pair is proving. Different starting position,
// velocity and colors purely so a screenshot can tell the two windows
// apart at a glance.

import "../../libsys/imports"
import "../user_runtime"
import "../wm_protocol"
import "../wm_client"

func _start(argc: u64, argv: u64*) {
    sys_putln("winball2: starting")
    if !wm_connect() {
        sys_putln("winball2: wm_connect failed")
        rt_exit(1)
    }
    if !wm_create_window() {
        sys_putln("winball2: create_window failed")
        rt_exit(1)
    }

    let ball_size: i64 = 10
    let win_w: i64 = Wm.WIN_W
    let win_h: i64 = Wm.WIN_H
    let bx: i64 = win_w - ball_size - 4
    let by: i64 = win_h - ball_size - 4
    let dx: i64 = -1
    let dy: i64 = -2

    while true {
        let input: WmInput = wm_poll_input()
        let key: u64 = input.key as u64
        if key == (KEY_CLOSE_REQ as u64) {
            wm_close()
            rt_exit(0)
        } else if key == (KEY_LEFT as u64) {
            dx = -1
        } else if key == (KEY_RIGHT as u64) {
            dx = 1
        } else if key == (KEY_UP as u64) {
            dy = -1
        } else if key == (KEY_DOWN as u64) {
            dy = 1
        }

        bx = bx + dx
        by = by + dy
        if bx < 0 {
            bx = 0
            dx = -dx
        }
        if by < 0 {
            by = 0
            dy = -dy
        }
        if bx + ball_size > win_w {
            bx = win_w - ball_size
            dx = -dx
        }
        if by + ball_size > win_h {
            by = win_h - ball_size
            dy = -dy
        }

        wm_fill(0x400000)
        let yy: i64 = 0
        while yy < ball_size {
            let xx: i64 = 0
            while xx < ball_size {
                wm_put_pixel((bx + xx) as u64, (by + yy) as u64, 0x30D030)
                xx = xx + 1
            }
            yy = yy + 1
        }
        wm_present()
        sys_sleep(20)
    }
}
