// Dynamically linked LLPL user program.
//
// Linked as ET_DYN with a DT_NEEDED dependency on /boot/libsys.so.

import "../../libsys/imports"

func print_digit(n: u64) {
    let buf: char[2]
    buf[0] = (48 + n) as char
    buf[1] = 0
    sys_puts(buf as char*)
}

func print_uint(n: u64) {
    if n >= 10 {
        print_uint(n / 10)
    }
    print_digit(n % 10)
}

func _start(argc: u64, argv: u64*) {
    sys_putln("Hello from a dynamically linked LLPL executable.")
    sys_puts("pid=")
    print_uint(sys_getpid())
    sys_puts(" argc=")
    print_uint(argc)
    sys_puts(" argv:")

    let i: u64 = 0
    while i < argc {
        sys_puts(" ")
        sys_puts(argv[i] as char*)
        i = i + 1
    }
    sys_puts("\n")

    let block: u8* = sys_malloc(5000)
    if block != null {
        block[0] = 65 as u8
        block[4999] = 90 as u8
        sys_puts("large free=")
        print_uint(sys_free(block))
        sys_puts("\n")
    } else {
        sys_putln("large malloc failed")
    }

    sys_puts("small alloc1...\n")
    let small1: u8* = sys_malloc(64)
    let small2: u8* = null
    if small1 != null {
        small1[0] = 49 as u8
        sys_puts("small free1=")
        print_uint(sys_free(small1))
        sys_puts("\n")
        sys_puts("small alloc2...\n")
        small2 = sys_malloc(32)
    } else {
        sys_puts("small alloc1 failed\n")
    }
    sys_puts("small reuse=")
    if small1 != null && (small2 as u64) == (small1 as u64) {
        print_uint(1)
    } else {
        print_uint(0)
    }
    sys_puts("\n")

    sys_exit(0)
    while true {
    }
}
