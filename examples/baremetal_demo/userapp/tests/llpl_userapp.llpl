// Tiny ring-3 user program written in LLPL.
//
// Built by llplbuild's extra_links[].llpl_sources path into
// /boot/llpl_userapp.elf. Run it from the kernel shell with:
//
//   run /boot/llpl_userapp.elf alpha beta

const SYS_EXIT = 0
const SYS_PRINT = 1
const SYS_SLEEP = 5
const SYS_OPEN = 6
const SYS_READ = 7
const SYS_CLOSE = 9

func syscall1(number: u64, a: u64) -> u64 {
    let ret: u64 = 0
    asm("int $0x80" : "=a"(ret) : "a"(number), "D"(a) : "memory")
    return ret
}

func syscall2(number: u64, a: u64, b: u64) -> u64 {
    let ret: u64 = 0
    asm("int $0x80" : "=a"(ret) : "a"(number), "D"(a), "S"(b) : "memory")
    return ret
}

func syscall3(number: u64, a: u64, b: u64, c: u64) -> u64 {
    let ret: u64 = 0
    asm("int $0x80" : "=a"(ret) : "a"(number), "D"(a), "S"(b), "d"(c) : "memory")
    return ret
}

func user_strlen(s: u8*) -> u64 {
    let n: u64 = 0
    while s[n] != 0 {
        n = n + 1
    }
    return n
}

func print(s: u8*) {
    syscall2(SYS_PRINT, s as u64, user_strlen(s))
}

func print_bytes(s: u8*, len: u64) {
    syscall2(SYS_PRINT, s as u64, len)
}

func main(argc: u64, argv: u64*) {
    print("Hello from LLPL user-space!\n")
    print("argv:")

    let i: u64 = 0
    while i < argc {
        print(" ")
        print(argv[i] as u8*)
        i = i + 1
    }
    print("\n")

    syscall1(SYS_SLEEP, 3)

    let fd: u64 = syscall2(SYS_OPEN, "/boot/readme.txt" as u64, 0)
    if fd != 0xFFFFFFFFFFFFFFFF {
        let buf: u8[160]
        let n: u64 = syscall3(SYS_READ, fd, buf as u64, 159)
        if n != 0xFFFFFFFFFFFFFFFF {
            print("readme: ")
            print_bytes(buf as u8*, n)
            print("\n")
        }
        syscall1(SYS_CLOSE, fd)
    }
}

func _start(argc: u64, argv: u64*) {
    main(argc, argv)
    syscall1(SYS_EXIT, 0)
    while true {
    }
}
