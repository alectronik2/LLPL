// Minimal windowing compositor. Owns the real framebuffer exclusively
// (maps it once via sys_fb_map) and one shared pixel arena (one
// sys_shm_create call, sliced i64o Wm.MAX_WINDOWS equal fixed-size
// windows - see wm_protocol.llpl for why the sizes are what they are).
// Clients never touch the real framebuffer or each other's memory: each
// one sys_lookup("wm")s this service, sys_shm_maps the arena (the exact
// same shared-region pattern shmserver/shmclient already prove works),
// and only ever writes i64o its own WIN_BYTES-sized slice of it. This
// service is the only thing that ever reads the arena and the only thing
// that ever writes the real framebuffer - a client's dodgy slot index
// can't corrupt another client's pixels because writes off the end of
// its own slice just land in ITS OWN, still-shared arena memory (the
// slot bounds check on every request keeps a bad index from being
// *blitted* anywhere, but doesn't need to since nothing here trusts a
// slot argument without checking it against Wm.MAX_WINDOWS first anyway).
//
// Protocol (see wm_protocol.llpl): a client sends {op, slot} over the
// ordinary small-message IPC path (block_current_send/sys_msg_reply -
// the same primitives ata.llpl and every ring-3 IPC demo already use) and
// gets a fixed-shape reply back. There is no push channel from this
// service to a client - input delivery is pull-based (OP_POLL_INPUT),
// exactly like Syscall.sys_kbd_poll itself, so a client's own main loop
// just polls once per frame the same way tetris.llpl already does.
//
// Focus and input routing: only the currently focused window's
// OP_POLL_INPUT calls sys_kbd_poll() at all - an unfocused window's poll
// returns key=0 without ever touching the keyboard driver, so a
// keystroke can't be silently stolen by whichever window happens to ask
// first. TAB (ASCII 9) is i64ercepted here to cycle focus between
// windows and is never forwarded to a client.

import "../libsys/imports"
import "user_runtime"
import "wm_protocol"
import "font"
import "png_decoder"
import "embedded_images"
import "embedded_font"

struct Window {
    let used: bool
    let owner_pid: i64
    // Top-left of the whole decorated window (titlebar included) in real
    // screen coordinates - mutable, unlike the old fixed window_x/y
    // formula, so a titlebar drag (see hit_test_titlebar/main loop below)
    // can move it. A client never sees or chooses these: it only ever
    // draws i64o its own fixed-size WIN_W x WIN_H slice of the arena in
    // local coordinates (wm_client.llpl's wm_put_pixel/wm_fill) - this
    // service alone decides where that content lands on the real screen.
    let win_x: u64
    let win_y: u64
    // How much of the client's fixed WIN_W x WIN_H arena slice is
    // actually visible/blitted on screen - a viewport crop, not true
    // per-window resizing: the client's own drawing canvas never changes
    // size (that would need a variable-size SHM region per client, which
    // this kernel's handle model can't grant wm without wm being the one
    // that sys_spawn'd the client - see sys_shm_map's own doc comment).
    // Shrinking via the resize grip (see hit_test_resize_grip) just shows
    // less of what the client already drew; growing back can only ever
    // reveal up to the original WIN_W x WIN_H, never more.
    let vis_w: u64
    let vis_h: u64
    let restore_x: u64
    let restore_y: u64
    let restore_w: u64
    let restore_h: u64
    let minimized: bool
    let maximized: bool
    // Set by the close button (see hit_test_close_button in the main
    // loop), cleared the moment OP_POLL_INPUT next delivers KEY_CLOSE_REQ
    // for this slot - a *request*, not an immediate close: the window
    // stays fully open and rendering until the owning client itself
    // calls OP_CLOSE (wm_close), which lets a client with state to lose
    // (the text editor's unsaved-changes prompt) decide whether/when
    // that actually happens instead of being force-removed out from
    // under it with no chance to object.
    let close_requested: bool
    // Window title (simplified - just store PID as identifier for now)
    let title: u8[32]
}

const MIN_VIS_W: u64 = 80
const MIN_VIS_H: u64 = 60
const DEFAULT_VIS_W: u64 = 320
const DEFAULT_VIS_H: u64 = 200
const RESIZE_GRIP: u64 = 10
const CLOSE_BTN: u64 = 10

// Height of the draggable titlebar strip drawn above each window's
// content - purely a compositor-side decoration, no protocol change
// needed since clients never see screen coordinates at all (see Window
// above).
const TITLEBAR_H: u64 = 18
const TITLEBAR_FOCUSED: u32 = 0xE8E8E8
const TITLEBAR_UNFOCUSED: u32 = 0xC8C8C8
const BACKDROP_COLOR: u32 = 0x1E1E2E
// How opaque a window's content/titlebar background is against whatever
// is already composited underneath it (0 = fully see-through, 255 =
// fully opaque) - see blit_window/draw_titlebar, where this blends
// against fb_get_pixel's read of the backbuf rather than overwriting it
// outright. Buttons, borders, the resize grip, and text stay fully
// opaque on top of that - only the flat window/titlebar fill is tinted,
// matching a typical "vibrancy" look rather than making everything
// (including small text) hard to read.
const WINDOW_ALPHA: u32 = 200
const CURSOR_COLOR: u32 = 0x000000
const SHADOW_OFFSET: u64 = 6
const SHADOW_COLOR: u32 = 0x000000

// Wallpaper gradient colors (top to bottom)
const WALLPAPER_TOP: u32 = 0x2A1B3D
const WALLPAPER_BOTTOM: u32 = 0x1A0F28

let windows: Window[4] // must match Wm.MAX_WINDOWS literally - see task.llpl's
                        // own MAX_LIBS/libs[] comment for why this can't just
                        // reference the const
let focused: i64 = -1
// Z-order for window drawing: z_order[i] contains the slot index to draw
// at position i. Lower positions draw first (back), higher positions draw
// last (front). When a window is clicked, it's moved to the highest
// position (topmost).
let z_order: i64[4]
let z_count: i64 = 0
// Wheel notches accumulated since the last time OP_POLL_INPUT handed
// them off to the focused window (handle_request, below) - a module
// global, not a main-loop local, since handle_request (a separate
// top-level function) needs to read and reset it too, the same way it
// already reads/writes `focused` itself.
let wheel_accum: i64 = 0
// Global mouse state for passing to clients
let global_mouse_x: i64 = 0
let global_mouse_y: i64 = 0
let global_mouse_left: bool = false
let global_mouse_right: bool = false
let arena: u8* = null
let fb: u8* = null
let fb_pitch: u64 = 0
let fb_width: u64 = 0
let fb_height: u64 = 0
// Everything gets drawn i64o this off-screen buffer (same size as the
// real framebuffer) instead of straight to `fb` - present_frame (below)
// is then the only thing that ever writes to the real framebuffer, in
// one single pass at the very end of a tick. Without this, each of
// fill_backdrop/draw_titlebar/blit_window/draw_cursor was its own
// separate burst of real-framebuffer writes, so anything glancing at
// the screen between those bursts (including real hardware's own
// display refresh, not just a debugging screendump) could catch a
// partially-composited frame - backdrop cleared but a window not yet
// redrawn on top of it, one window's new position but not another's,
// etc. Visually that reads as flicker, worse the more windows/redraw
// work there is per tick.
let backbuf: u8* = null

// Embedded wallpaper and cursor images
let wallpaper_tile: EmbeddedImage
let cursor_img: EmbeddedImage
let start_icon_terminal: EmbeddedImage
let start_icon_file: EmbeddedImage
let start_icon_app: EmbeddedImage

// The compositor stays purely reactive (blocking sys_msg_recv, never
// touching the real framebuffer beyond a client's own explicit present())
// until the first window ever exists - no poi64 owning the screen or
// ticking a redraw loop when there's nothing to draw and the boot
// console's own text is still the only thing on screen. Once true, it
// stays true forever (see the main loop below): a real desktop still
// shows a background + cursor with zero windows open, so there's no
// reason to revert once every window has been closed again.
let active: bool = false

func find_free_slot() -> i64 {
    let i: i64 = 0
    while i < Wm.MAX_WINDOWS {
        if !windows[i].used {
            return i
        }
        i = i + 1
    }
    return -1
}

// Add a window to the z-order stack (at the top/front)
func z_add(slot: i64) {
    z_order[z_count] = slot
    z_count = z_count + 1
}

// Remove a window from the z-order stack
func z_remove(slot: i64) {
    let i: i64 = 0
    let found: i64 = -1
    while i < z_count {
        if z_order[i] == slot {
            found = i
        }
        i = i + 1
    }
    if found >= 0 {
        // Shift everything after it down
        i = found
        while i < z_count - 1 {
            z_order[i] = z_order[i + 1]
            i = i + 1
        }
        z_count = z_count - 1
    }
}

// Bring a window to the front by moving it to the end of the z-order
func z_bring_to_front(slot: i64) {
    z_remove(slot)
    z_add(slot)
}

func restore_window(slot: i64) {
    if slot < 0 || slot >= Wm.MAX_WINDOWS || !windows[slot].used {
        return
    }
    windows[slot].minimized = false
    if windows[slot].maximized {
        return
    }
    if windows[slot].restore_w >= MIN_VIS_W && windows[slot].restore_h >= MIN_VIS_H {
        windows[slot].win_x = windows[slot].restore_x
        windows[slot].win_y = windows[slot].restore_y
        windows[slot].vis_w = windows[slot].restore_w
        windows[slot].vis_h = windows[slot].restore_h
    }
}

func minimize_window(slot: i64) {
    if slot < 0 || slot >= Wm.MAX_WINDOWS || !windows[slot].used {
        return
    }
    windows[slot].minimized = true
    if focused == slot {
        focused = -1
        let zi: i64 = z_count - 1
        while zi >= 0 && focused < 0 {
            let s: i64 = z_order[zi]
            if windows[s].used && !windows[s].minimized {
                focused = s
            }
            zi = zi - 1
        }
    }
}

func toggle_maximize_window(slot: i64) {
    if slot < 0 || slot >= Wm.MAX_WINDOWS || !windows[slot].used {
        return
    }
    windows[slot].minimized = false
    if windows[slot].maximized {
        windows[slot].maximized = false
        restore_window(slot)
        return
    }
    windows[slot].restore_x = windows[slot].win_x
    windows[slot].restore_y = windows[slot].win_y
    windows[slot].restore_w = windows[slot].vis_w
    windows[slot].restore_h = windows[slot].vis_h
    windows[slot].win_x = 0
    windows[slot].win_y = 0
    windows[slot].vis_w = max_visible_w_for(slot) as u64
    windows[slot].vis_h = max_visible_h_for(slot) as u64
    windows[slot].maximized = true
}

func snap_window_rect(slot: i64, x: i64, y: i64, w: i64, h: i64) {
    if slot < 0 || slot >= Wm.MAX_WINDOWS || !windows[slot].used {
        return
    }
    windows[slot].restore_x = windows[slot].win_x
    windows[slot].restore_y = windows[slot].win_y
    windows[slot].restore_w = windows[slot].vis_w
    windows[slot].restore_h = windows[slot].vis_h
    windows[slot].win_x = x as u64
    windows[slot].win_y = y as u64
    windows[slot].vis_w = w as u64
    windows[slot].vis_h = h as u64
    windows[slot].minimized = false
    windows[slot].maximized = false
}

func apply_drag_snap(slot: i64, mx: i64, my: i64) {
    if slot < 0 || slot >= Wm.MAX_WINDOWS || !windows[slot].used {
        return
    }
    let max_x: i64 = (fb_width as i64)
    let max_y: i64 = (fb_height as i64)
    if my <= SNAP_EDGE_PX {
        toggle_maximize_window(slot)
        return
    }
    if mx <= SNAP_EDGE_PX {
        let half_w: i64 = max_x / 2
        snap_window_rect(slot, 0, 0, half_w, max_y - (TASKBAR_H as i64))
        return
    }
    if mx >= max_x - SNAP_EDGE_PX {
        let half_w: i64 = max_x / 2
        snap_window_rect(slot, half_w, 0, half_w, max_y - (TASKBAR_H as i64))
        return
    }
}

// Next used slot strictly after `cur`, wrapping around - -1 if none are
// used at all (can't happen mid-dispatch of a request from an existing
// window, but a defensive return value costs nothing).
func next_focus_after(cur: i64) -> i64 {
    let i: i64 = 0
    while i < Wm.MAX_WINDOWS {
        let idx: i64 = (cur + 1 + i) % Wm.MAX_WINDOWS
        if windows[idx].used && !windows[idx].minimized {
            return idx
        }
        i = i + 1
    }
    return -1
}

// Initial placement for a newly created window - a small cascade rather
// than the old left-to-right tiling: windows grew from 104x52 demo size
// to 320x200 app size (see wm_protocol.llpl), so tiling MAX_WINDOWS of
// them side by side would run off the right edge of a typical screen.
// Just a starting point either way, not permanent: the user can drag it
// anywhere afterward.
func initial_window_x(slot: i64) -> u64 {
    return 40 + (slot as u64) * 40
}

func initial_window_y(slot: i64) -> u64 {
    return 40 + (slot as u64) * 30
}

func max_visible_w_for(slot: i64) -> i64 {
    let room: i64 = (fb_width as i64) - (windows[slot].win_x as i64)
    return clampi(room, MIN_VIS_W as i64, Wm.WIN_W)
}

func max_visible_h_for(slot: i64) -> i64 {
    let room: i64 = (fb_height as i64) - (windows[slot].win_y as i64) - (TITLEBAR_H as i64) - 32
    return clampi(room, MIN_VIS_H as i64, Wm.WIN_H)
}

func clampi(v: i64, lo: i64, hi: i64) -> i64 {
    if v < lo {
        return lo
    }
    if v > hi {
        return hi
    }
    return v
}

// Bounds-checked write into the back buffer at absolute screen
// coordinates - used for the titlebar/backdrop/cursor, all of which are
// compositor-owned pixels with no arena slice behind them (contrast
// blit_window below, which copies a client's own content).
func fb_put_pixel(px: i64, py: i64, color: u32) {
    if px < 0 || py < 0 || (px as u64) >= fb_width || (py as u64) >= fb_height {
        return
    }
    let offset: u64 = (py as u64) * fb_pitch + (px as u64) * 4
    let p: u32* = (backbuf + offset) as u32*
    p[0] = color
}

// The read counterpart to fb_put_pixel - used to blend semi-transparent
// window/titlebar pixels (see WINDOW_ALPHA) against whatever's already
// been composited underneath: the backdrop, or another window drawn
// earlier this same tick (redraw_windows draws back-to-front, so an
// earlier window in z-order is always already in backbuf by the time a
// later, higher one blends against it).
func fb_get_pixel(px: i64, py: i64) -> u32 {
    if px < 0 || py < 0 || (px as u64) >= fb_width || (py as u64) >= fb_height {
        return BACKDROP_COLOR
    }
    let offset: u64 = (py as u64) * fb_pitch + (px as u64) * 4
    let p: u32* = (backbuf + offset) as u32*
    return p[0]
}

// Draw the wallpaper photo (embedded at compile time, see
// load_wallpaper_photo - scaled up to fill the real screen, not tiled).
// A full-screen pixel fill (potentially hundreds of thousands of writes
// at real resolutions) - used to only run when something might have
// exposed bare screen a window no longer covers (a drag/resize in
// progress, or a window just created/closed), skipped otherwise to save
// the CPU cost. Now runs unconditionally every tick instead: semi-
// transparent windows (see WINDOW_ALPHA, blit_window/draw_titlebar) blend
// against whatever's already in backbuf, so that background has to be
// this tick's real backdrop, not however many ticks ago the last drag or
// window open/close happened to be - blending against a stale backbuf
// would compound a little further from correct every tick instead of
// settling on a stable image. This never risks exposing a half-composited
// frame externally the way an earlier version of this comment worried
// about: present_frame's single bulk copy is the only thing that ever
// touches the real framebuffer, always called after every compositing
// step below (including this one) has already finished for the tick.
func fill_backdrop() {
    let tile_w: u32 = wallpaper_tile.width
    let tile_h: u32 = wallpaper_tile.height

    if fb_width == 0 || fb_height == 0 || tile_w == 0 || tile_h == 0 {
        let row: u64 = 0
        while row < fb_height {
            let col: u64 = 0
            while col < fb_width {
                let offset: u64 = row * fb_pitch + col * 4
                let p: u32* = (backbuf + offset) as u32*
                p[0] = BACKDROP_COLOR
                col = col + 1
            }
            row = row + 1
        }
        return
    }

    let row: u64 = 0
    while row < fb_height {
        let col: u64 = 0
        while col < fb_width {
            // Scale the embedded wallpaper photo to fill the real
            // screen exactly once (not tiled/repeated - a real photo's
            // large-scale features, unlike the old procedural pattern
            // this replaced, would look obviously repetitive tiled at
            // any resolution small enough to embed).
            let tile_x: u32 = (col * (tile_w as u64) / fb_width) as u32
            let tile_y: u32 = (row * (tile_h as u64) / fb_height) as u32
            let color: u32 = get_pixel(wallpaper_tile, tile_x, tile_y)

            let offset: u64 = row * fb_pitch + col * 4
            let p: u32* = (backbuf + offset) as u32*
            p[0] = color

            col = col + 1
        }
        row = row + 1
    }
}

func fill_backdrop_rect(x0: i64, y0: i64, w: i64, h: i64) {
    let tile_w: u32 = wallpaper_tile.width
    let tile_h: u32 = wallpaper_tile.height
    let y: i64 = 0
    while y < h {
        let py: i64 = y0 + y
        let x: i64 = 0
        while x < w {
            let px: i64 = x0 + x
            if px >= 0 && py >= 0 && (px as u64) < fb_width && (py as u64) < fb_height {
                let color: u32 = BACKDROP_COLOR
                if tile_w != 0 && tile_h != 0 && fb_width != 0 && fb_height != 0 {
                    let tile_x: u32 = ((px as u64) * (tile_w as u64) / fb_width) as u32
                    let tile_y: u32 = ((py as u64) * (tile_h as u64) / fb_height) as u32
                    color = get_pixel(wallpaper_tile, tile_x, tile_y)
                }
                let offset: u64 = (py as u64) * fb_pitch + (px as u64) * 4
                let p: u32* = (backbuf + offset) as u32*
                p[0] = color
            }
            x = x + 1
        }
        y = y + 1
    }
}

// macOS traffic light button colors
const BTN_CLOSE_COLOR: u32 = 0xFF5F56
const BTN_MINIMIZE_COLOR: u32 = 0xFFBD2E
const BTN_MAXIMIZE_COLOR: u32 = 0x27C93F
const BTN_SIZE: u64 = 8
const BTN_SPACING: u64 = 6
const RESIZE_GRIP_COLOR: u32 = 0x808080

// Draw a soft drop shadow around a window - drawn with alpha-like
// darkening by blending with the backdrop color rather than true
// transparency (no alpha channel in the framebuffer), creating a
// gradient effect that fades from pure shadow near the window edge
// to pure backdrop further out.
// Draw a subtle border around the entire window (titlebar + content area)
// to give it definition against the backdrop
const BORDER_COLOR: u32 = 0x505050
const BORDER_COLOR_FOCUSED: u32 = 0x707070
// Widened from a 1px hairline to a chunkier frame - easier to see, and
// makes the window's edge (where a resize grab is expected to work,
// see hit_test_resize_grip's own generous zone) look as grabbable as it
// actually is instead of implying a razor-thin target.
const BORDER_THICKNESS: u64 = 3

func draw_window_border(slot: i64) {
    let ox: i64 = windows[slot].win_x as i64
    let oy: i64 = windows[slot].win_y as i64
    let vis_w: u64 = windows[slot].vis_w
    let total_h: u64 = TITLEBAR_H + windows[slot].vis_h

    let border_col: u32 = BORDER_COLOR
    if slot == focused {
        border_col = BORDER_COLOR_FOCUSED
    }

    let t: i64 = 0
    while (t as u64) < BORDER_THICKNESS {
        // Top edge
        let x: i64 = 0
        while (x as u64) < vis_w {
            fb_put_pixel(ox + x, oy + t, border_col)
            x = x + 1
        }

        // Bottom edge
        x = 0
        while (x as u64) < vis_w {
            fb_put_pixel(ox + x, oy + (total_h as i64) - 1 - t, border_col)
            x = x + 1
        }

        // Left edge
        let y: i64 = 0
        while (y as u64) < total_h {
            fb_put_pixel(ox + t, oy + y, border_col)
            y = y + 1
        }

        // Right edge
        y = 0
        while (y as u64) < total_h {
            fb_put_pixel(ox + (vis_w as i64) - 1 - t, oy + y, border_col)
            y = y + 1
        }

        t = t + 1
    }
}

func draw_shadow(slot: i64) {
    let ox: i64 = windows[slot].win_x as i64
    let oy: i64 = windows[slot].win_y as i64
    let vis_w: u64 = windows[slot].vis_w
    let total_h: u64 = TITLEBAR_H + windows[slot].vis_h

    // Shadow opacity levels - higher = darker, simulating distance from window
    let i: i64 = 0
    while (i as u64) < SHADOW_OFFSET {
        // Calculate opacity (0-255) based on distance from window edge
        let opacity: i64 = 80 - (i * 80 / (SHADOW_OFFSET as i64))

        // Blend shadow color with wallpaper gradient based on opacity
        let r_shadow: i64 = (SHADOW_COLOR >> 16) & 0xFF
        let g_shadow: i64 = (SHADOW_COLOR >> 8) & 0xFF
        let b_shadow: i64 = SHADOW_COLOR & 0xFF

        // Draw right edge of shadow
        let sy: i64 = i
        while (sy as u64) < total_h + SHADOW_OFFSET {
            let wall_color: u32 = get_wallpaper_color(ox + (vis_w as i64) + i, oy + sy)
            let r_back: i64 = (wall_color >> 16) & 0xFF
            let g_back: i64 = (wall_color >> 8) & 0xFF
            let b_back: i64 = wall_color & 0xFF

            let r: i64 = (r_shadow * opacity + r_back * (255 - opacity)) / 255
            let g: i64 = (g_shadow * opacity + g_back * (255 - opacity)) / 255
            let b: i64 = (b_shadow * opacity + b_back * (255 - opacity)) / 255
            let shadow_blend: u32 = ((r << 16) | (g << 8) | b) as u32

            fb_put_pixel(ox + (vis_w as i64) + i, oy + sy, shadow_blend)
            sy = sy + 1
        }

        // Draw bottom edge of shadow
        let sx: i64 = i
        while (sx as u64) < vis_w + SHADOW_OFFSET {
            let wall_color: u32 = get_wallpaper_color(ox + sx, oy + (total_h as i64) + i)
            let r_back: i64 = (wall_color >> 16) & 0xFF
            let g_back: i64 = (wall_color >> 8) & 0xFF
            let b_back: i64 = wall_color & 0xFF

            let r: i64 = (r_shadow * opacity + r_back * (255 - opacity)) / 255
            let g: i64 = (g_shadow * opacity + g_back * (255 - opacity)) / 255
            let b: i64 = (b_shadow * opacity + b_back * (255 - opacity)) / 255
            let shadow_blend: u32 = ((r << 16) | (g << 8) | b) as u32

            fb_put_pixel(ox + sx, oy + (total_h as i64) + i, shadow_blend)
            sx = sx + 1
        }

        i = i + 1
    }
}

func draw_titlebar(slot: i64) {
    let color: u32 = TITLEBAR_UNFOCUSED
    if slot == focused {
        color = TITLEBAR_FOCUSED
    }
    let ox: i64 = windows[slot].win_x as i64
    let oy: i64 = windows[slot].win_y as i64
    let vis_w: u64 = windows[slot].vis_w
    let row: u64 = 0
    while row < TITLEBAR_H {
        let col: u64 = 0
        while col < vis_w {
            let px: i64 = ox + (col as i64)
            let py: i64 = oy + (row as i64)
            let bg: u32 = fb_get_pixel(px, py)
            fb_put_pixel(px, py, blend_alpha(color, bg, WINDOW_ALPHA))
            col = col + 1
        }
        row = row + 1
    }

    // Draw separator line between titlebar and content
    let sep_x: i64 = 0
    while (sep_x as u64) < vis_w {
        fb_put_pixel(ox + sep_x, oy + (TITLEBAR_H as i64) - 1, 0xB0B0B0)
        sep_x = sep_x + 1
    }

    // Draw window title with TrueType
    let title_x: i64 = ox + 55  // After traffic light buttons
    let title_y: i64 = oy + 3
    let title_color: u32 = 0x000000
    if slot != focused {
        title_color = 0x666666  // Dimmer for unfocused
    }
    wm_draw_ttf_string(title_x, title_y, windows[slot].title as u8*, 11, title_color, color)

    // macOS-style traffic light buttons: red (close), yellow (minimize),
    // green (maximize) - drawn as circles from left to right
    let btn_y_center: i64 = oy + ((TITLEBAR_H as i64) / 2)
    let btn_x_start: i64 = ox + 10

    // Draw all three buttons
    let btn_idx: i64 = 0
    while btn_idx < 3 {
        let btn_color: u32 = BTN_CLOSE_COLOR
        if btn_idx == 1 {
            btn_color = BTN_MINIMIZE_COLOR
        } else if btn_idx == 2 {
            btn_color = BTN_MAXIMIZE_COLOR
        }

        let btn_x_center: i64 = btn_x_start + btn_idx * ((BTN_SIZE as i64) + (BTN_SPACING as i64))
        let radius: i64 = (BTN_SIZE as i64) / 2

        // Draw filled circle using distance formula
        let dy: i64 = -(radius + 1)
        while dy <= radius + 1 {
            let dx: i64 = -(radius + 1)
            while dx <= radius + 1 {
                if dx * dx + dy * dy <= radius * radius {
                    fb_put_pixel(btn_x_center + dx, btn_y_center + dy, btn_color)
                }
                dx = dx + 1
            }
            dy = dy + 1
        }

        btn_idx = btn_idx + 1
    }
}

// Resize grip in the bottom-right corner: parallel diagonal lines
// forming a recognizable resize indicator, similar to macOS window
// resize handles - sized to actually look as big as the generous
// hit-test zone around it (see hit_test_resize_grip), not just a tiny
// subtle mark implying a much smaller target than what really responds.
func draw_resize_grip(slot: i64) {
    let ox: i64 = windows[slot].win_x as i64
    let oy: i64 = windows[slot].win_y as i64 + (TITLEBAR_H as i64)
    let vis_w: i64 = windows[slot].vis_w as i64
    let vis_h: i64 = windows[slot].vis_h as i64

    // Five thicker diagonal lines (each stroke widened by also drawing
    // the pixel just right/below it) instead of three thin ones.
    let line: i64 = 0
    while line < 5 {
        let i: i64 = 0
        while i < 14 {
            let x: i64 = ox + vis_w - 4 - i - (line * 4)
            let y: i64 = oy + vis_h - 4 + i - (line * 4)
            fb_put_pixel(x, y, RESIZE_GRIP_COLOR)
            fb_put_pixel(x + 1, y, RESIZE_GRIP_COLOR)
            fb_put_pixel(x, y + 1, RESIZE_GRIP_COLOR)
            i = i + 1
        }
        line = line + 1
    }
}

// Draw cursor from embedded image with alpha blending
func draw_cursor(cx: i64, cy: i64) {
    let cw: u32 = cursor_img.width
    let ch: u32 = cursor_img.height

    let y: u32 = 0
    while y < ch {
        let x: u32 = 0
        while x < cw {
            let alpha: u32 = get_pixel_alpha(cursor_img, x, y)
            if alpha > 0 {
                let cursor_color: u32 = get_pixel(cursor_img, x, y)
                let screen_x: i64 = cx + (x as i64)
                let screen_y: i64 = cy + (y as i64)

                if alpha == 255 {
                    // Fully opaque - just draw the pixel
                    fb_put_pixel(screen_x, screen_y, cursor_color)
                } else {
                    // Semi-transparent - blend with background
                    // Get background color
                    if screen_x >= 0 && screen_y >= 0 &&
                       (screen_x as u64) < fb_width && (screen_y as u64) < fb_height {
                        let bg_offset: u64 = (screen_y as u64) * fb_pitch + (screen_x as u64) * 4
                        let bg_p: u32* = (backbuf + bg_offset) as u32*
                        let bg_color: u32 = bg_p[0]
                        let blended: u32 = blend_alpha(cursor_color, bg_color, alpha)
                        fb_put_pixel(screen_x, screen_y, blended)
                    }
                }
            }
            x = x + 1
        }
        y = y + 1
    }
}

// Calculate wallpaper color at a specific pixel position (for shadow blending)
func get_wallpaper_color(px: i64, py: i64) -> u32 {
    if px < 0 || py < 0 || (px as u64) >= fb_width || (py as u64) >= fb_height {
        return BACKDROP_COLOR
    }

    let tile_w: u32 = wallpaper_tile.width
    let tile_h: u32 = wallpaper_tile.height
    if tile_w == 0 || tile_h == 0 || fb_width == 0 || fb_height == 0 {
        return BACKDROP_COLOR
    }
    let tile_x: u32 = ((px as u64) * (tile_w as u64) / fb_width) as u32
    let tile_y: u32 = ((py as u64) * (tile_h as u64) / fb_height) as u32

    return get_pixel(wallpaper_tile, tile_x, tile_y)
}

// Copies one window's slice of the shared arena into the real
// framebuffer at its current screen position (below its titlebar) - the
// only place a client's own pixels ever reach real video memory. Blended
// (see WINDOW_ALPHA) against whatever's already in backbuf rather than
// overwritten outright, so the desktop (or a window further back in
// z-order) shows through slightly - this is why fill_backdrop now runs
// every tick (see the main loop) instead of only when something moved:
// blending against a stale backbuf would compound a little more each
// tick instead of settling on a stable result.
func blit_window(slot: i64) {
    let src: u32* = (arena + (slot as u64) * Wm.WIN_BYTES) as u32*
    let ox: u64 = windows[slot].win_x
    let oy: u64 = windows[slot].win_y + TITLEBAR_H
    let vis_w: u64 = windows[slot].vis_w
    let vis_h: u64 = windows[slot].vis_h
    let row: u64 = 0
    while row < vis_h {
        let col: u64 = 0
        while col < vis_w {
            // Indexed by the client's *actual* WIN_W stride regardless of
            // how much is currently visible - only the loop bounds above
            // shrink for a cropped window, never this addressing math,
            // since the client's own arena layout never changes size.
            let pixel: u32 = src[row * (Wm.WIN_W as u64) + col]
            let offset: u64 = (oy + row) * fb_pitch + (ox + col) * 4
            let p: u32* = (backbuf + offset) as u32*
            p[0] = blend_alpha(pixel, p[0], WINDOW_ALPHA)
            col = col + 1
        }
        row = row + 1
    }
}

func blit_window_rect(slot: i64, sx0: i64, sy0: i64, w: i64, h: i64) {
    if w <= 0 || h <= 0 {
        return
    }
    let src: u32* = (arena + (slot as u64) * Wm.WIN_BYTES) as u32*
    let ox: i64 = windows[slot].win_x as i64
    let oy: i64 = (windows[slot].win_y as i64) + (TITLEBAR_H as i64)
    let vis_w: i64 = windows[slot].vis_w as i64
    let vis_h: i64 = windows[slot].vis_h as i64

    let x1: i64 = clampi(sx0, 0, vis_w)
    let y1: i64 = clampi(sy0, 0, vis_h)
    let x2: i64 = clampi(sx0 + w, 0, vis_w)
    let y2: i64 = clampi(sy0 + h, 0, vis_h)
    let y: i64 = y1
    while y < y2 {
        let x: i64 = x1
        while x < x2 {
            let screen_x: i64 = ox + x
            let screen_y: i64 = oy + y
            if screen_x >= 0 && screen_y >= 0 && (screen_x as u64) < fb_width && (screen_y as u64) < fb_height {
                let pixel: u32 = src[(y as u64) * (Wm.WIN_W as u64) + (x as u64)]
                let offset: u64 = (screen_y as u64) * fb_pitch + (screen_x as u64) * 4
                let p: u32* = (backbuf + offset) as u32*
                p[0] = blend_alpha(pixel, p[0], WINDOW_ALPHA)
            }
            x = x + 1
        }
        y = y + 1
    }
}

func copy_rect_to_framebuffer(x0: i64, y0: i64, w: i64, h: i64) {
    if w <= 0 || h <= 0 {
        return
    }
    let x1: i64 = clampi(x0, 0, fb_width as i64)
    let y1: i64 = clampi(y0, 0, fb_height as i64)
    let x2: i64 = clampi(x0 + w, 0, fb_width as i64)
    let y2: i64 = clampi(y0 + h, 0, fb_height as i64)
    let y: i64 = y1
    while y < y2 {
        let src: u64* = (backbuf + (y as u64) * fb_pitch + (x1 as u64) * 4) as u64*
        let dst: u64* = (fb + (y as u64) * fb_pitch + (x1 as u64) * 4) as u64*
        let bytes: u64 = ((x2 - x1) as u64) * 4
        let words: u64 = bytes / 8
        let i: u64 = 0
        while i < words {
            dst[i] = src[i]
            i = i + 1
        }
        let done: u64 = words * 8
        let rem: u64 = bytes - done
        let src_tail: u8* = ((src as u8*) + done) as u8*
        let dst_tail: u8* = ((dst as u8*) + done) as u8*
        let j: u64 = 0
        while j < rem {
            dst_tail[j] = src_tail[j]
            j = j + 1
        }
        y = y + 1
    }
}

func present_window_rect(slot: i64, rx: i64, ry: i64, rw: i64, rh: i64) {
    if slot < 0 || slot >= Wm.MAX_WINDOWS || !windows[slot].used {
        return
    }
    let sx: i64 = (windows[slot].win_x as i64) + rx
    let sy: i64 = (windows[slot].win_y as i64) + (TITLEBAR_H as i64) + ry
    let w: i64 = clampi(rw, 0, windows[slot].vis_w as i64)
    let h: i64 = clampi(rh, 0, windows[slot].vis_h as i64)
    fill_backdrop_rect(sx, sy, w, h)

    let zi: i64 = 0
    while zi < z_count {
        let s: i64 = z_order[zi]
        if windows[s].used && !windows[s].minimized {
            let wx: i64 = windows[s].win_x as i64
            let wy: i64 = (windows[s].win_y as i64) + (TITLEBAR_H as i64)
            let ix1: i64 = clampi(sx, wx, wx + (windows[s].vis_w as i64))
            let iy1: i64 = clampi(sy, wy, wy + (windows[s].vis_h as i64))
            let ix2: i64 = clampi(sx + w, wx, wx + (windows[s].vis_w as i64))
            let iy2: i64 = clampi(sy + h, wy, wy + (windows[s].vis_h as i64))
            if ix2 > ix1 && iy2 > iy1 {
                blit_window_rect(s, ix1 - wx, iy1 - wy, ix2 - ix1, iy2 - iy1)
            }
        }
        zi = zi + 1
    }

    draw_cursor(global_mouse_x, global_mouse_y)
    copy_rect_to_framebuffer(sx, sy, w, h)
}

// Topmost-first (reverse slot order, matching redraw_all's draw order
// below, so a click where two windows' titlebars happen to overlap picks
// whichever one is actually drawn on top) hit-test against each used
// window's titlebar strip - -1 if the point isn't over any of them.
func hit_test_titlebar(mx: i64, my: i64) -> i64 {
    let zi: i64 = z_count - 1
    while zi >= 0 {
        let slot: i64 = z_order[zi]
        if windows[slot].used && !windows[slot].minimized {
            let ox: i64 = windows[slot].win_x as i64
            let oy: i64 = windows[slot].win_y as i64
            let vw: i64 = windows[slot].vis_w as i64
            if mx >= ox && mx < ox + vw && my >= oy && my < oy + (TITLEBAR_H as i64) {
                return slot
            }
        }
        zi = zi - 1
    }
    return -1
}

// Same topmost-first search, but against just the close button (red
// traffic light, leftmost of the three) in each used window's titlebar -
// checked before hit_test_titlebar in the main loop so a click there
// closes the window instead of starting a drag.
func hit_test_title_button(mx: i64, my: i64, btn_idx: i64) -> i64 {
    let zi: i64 = z_count - 1
    while zi >= 0 {
        let slot: i64 = z_order[zi]
        if windows[slot].used && !windows[slot].minimized {
            let ox: i64 = windows[slot].win_x as i64
            let oy: i64 = windows[slot].win_y as i64
            let btn_y_center: i64 = oy + ((TITLEBAR_H as i64) / 2)
            let btn_x_center: i64 = ox + 10 + btn_idx * ((BTN_SIZE as i64) + (BTN_SPACING as i64))
            let radius: i64 = (BTN_SIZE as i64) / 2

            let dx: i64 = mx - btn_x_center
            let dy: i64 = my - btn_y_center
            if dx * dx + dy * dy <= radius * radius {
                return slot
            }
        }
        zi = zi - 1
    }
    return -1
}

func hit_test_close_button(mx: i64, my: i64) -> i64 {
    return hit_test_title_button(mx, my, 0)
}

// Same again, against the resize grip in each used window's bottom-right
// corner (of its *visible*, possibly-shrunk area).
// Deliberately checked against a *larger* zone than RESIZE_GRIP's own
// drawn 10x10 triangle (see draw_resize_grip) - a fixed-size corner
// target gets harder to re-acquire the smaller a window has already
// been shrunk to (it moves closer to the content with every shrink),
// and grabbing it again is the *only* way to grow a window back. A
// purely pixel-exact hit-test against the visual triangle alone was a
// real, reproduced bug this fixed: growing looked broken because the
// second click (to re-grab an already-shrunk grip) missed by just a few
// pixels almost every time, even though the actual resize/grow logic
// underneath was always correct.
//
// A plain square around the corner (the first fix) still only gives an
// even-generous version of it a ~32x32 target once a window has been
// shrunk toward MIN_VIS_W/MIN_VIS_H, where the corner sits close to
// other window chrome - both mx AND my have to land in a narrow band at
// once. Real window managers accept a grab from anywhere along the
// bottom or right edge near the corner, not just the exact corner
// pixel, so this checks an "L" shaped strip instead: near the right
// edge for a good stretch of y above the bottom, OR near the bottom
// edge for a good stretch of x left of the right edge - only one axis
// has to be precise at a time, which is what made re-grabbing an
// already-shrunk corner to grow it back unreliable before.
//
// Widened again (20/40/16 -> 36/90/28): the first widening still wasn't
// generous enough in practice to reliably re-grab a shrunk corner. These
// are deliberately large - reaching most of the way up the right edge
// and left along the bottom edge of even a fully-shrunk (MIN_VIS_W x
// MIN_VIS_H) window - trading "might start a resize when the user meant
// to click content near the bottom-right" for "growing a shrunk window
// back actually works," since the latter was the reported, reproduced
// failure and the former is the safer direction to err in.
const RESIZE_EDGE_BAND: i64 = 36
const RESIZE_CORNER_REACH: i64 = 90
const RESIZE_GRIP_MARGIN: i64 = 28

func hit_test_resize_grip(mx: i64, my: i64) -> i64 {
    let zi: i64 = z_count - 1
    while zi >= 0 {
        let slot: i64 = z_order[zi]
        if windows[slot].used && !windows[slot].minimized {
            let vw: i64 = windows[slot].vis_w as i64
            let vh: i64 = windows[slot].vis_h as i64
            let ox: i64 = windows[slot].win_x as i64
            let oy: i64 = (windows[slot].win_y as i64) + (TITLEBAR_H as i64)
            let right: i64 = ox + vw
            let bottom: i64 = oy + vh
            let near_right: bool = mx >= right - RESIZE_EDGE_BAND && mx < right + RESIZE_GRIP_MARGIN
            let near_bottom: bool = my >= bottom - RESIZE_EDGE_BAND && my < bottom + RESIZE_GRIP_MARGIN
            let reaches_up: bool = my >= bottom - RESIZE_CORNER_REACH && my < bottom + RESIZE_GRIP_MARGIN
            let reaches_left: bool = mx >= right - RESIZE_CORNER_REACH && mx < right + RESIZE_GRIP_MARGIN
            if (near_right && reaches_up) || (near_bottom && reaches_left) {
                return slot
            }
        }
        zi = zi - 1
    }
    return -1
}

// Compositor-side text rendering, built on Font's glyph table (font.llpl)
// but going through fb_put_pixel one pixel at a time instead of Font's
// own draw_u8/draw_string - those assume a tightly-packed u32
// buffer addressed by pixel width, which is exactly what a client's own
// arena slice is, but NOT necessarily what backbuf is: fb_pitch (used by
// every other compositor-side draw in this file) can be wider than
// fb_width*4 if the real framebuffer has row padding, and reusing
// fb_put_pixel keeps this correct - and bounds-checked - regardless.
func wm_draw_u8(x: i64, y: i64, c: u8, fg: u32, bg: u32) {
    let code: i64 = c as i64
    if code < 32 || code > 126 {
        code = 32
    }
    let glyph_offset: i64 = (code - 32) * Font.GLYPH_HEIGHT
    let row: i64 = 0
    while row < Font.GLYPH_HEIGHT {
        let bits: i64 = (Font.font_data[glyph_offset + row] as i64) & 255
        let col: i64 = 0
        while col < Font.GLYPH_WIDTH {
            let mask: i64 = 128 >> col
            let color: u32 = bg
            if (bits & mask) != 0 {
                color = fg
            }
            fb_put_pixel(x + col, y + row, color)
            col = col + 1
        }
        row = row + 1
    }
}

func wm_draw_string(x: i64, y: i64, str: u8*, fg: u32, bg: u32) {
    let i: i64 = 0
    let cur_x: i64 = x
    while str[i] != 0 {
        wm_draw_u8(cur_x, y, str[i], fg, bg)
        cur_x = cur_x + Font.GLYPH_WIDTH
        i = i + 1
    }
}

// Render TrueType text directly to backbuffer
func wm_draw_ttf_string(x: i64, y: i64, str: u8*, size: i16, fg: u32, bg: u32) {
    // Create a temporary buffer for the backbuffer as u32*
    let buf: u32* = backbuf as u32*
    let buf_w: i16 = fb_width as i16
    let buf_h: i16 = fb_height as i16

    // Note: This assumes fb_pitch == fb_width * 4
    // For proper rendering, we'd need to account for pitch
    render_smooth_text(str, size, buf, buf_w, buf_h, x as i16, y as i16, fg, bg)
}

// Permanent launcher strip along the bottom of the screen, always drawn
// once wm is active (see draw_taskbar below) regardless of whether any
// window is currently open - the whole point is to be able to start the
// *first* app without ever touching the console. Lists /bin's contents
// once (load_taskbar), the same sys_readdir walk filebrowser.llpl uses
// to browse it interactively; click a button to sys_spawn it.
const TASKBAR_H: u64 = 32
const TASKBAR_BG: u32 = 0x2A2A2A
const TASKBAR_BTN: u32 = 0x404040
const TASKBAR_BTN_HOVER: u32 = 0x505050
const TASKBAR_TEXT: u32 = 0xF0F0F0
const TASKBAR_BTN_W: u64 = 96
const START_BTN_W: u64 = 76
const CLOCK_W: u64 = 64
const TRAY_W: u64 = 58
const CPU_GRAPH_W: u64 = 76
const CPU_GRAPH_H: u64 = 24
const CPU_GRAPH_SAMPLES: i64 = 48
const MENU_W: u64 = 184
const MENU_ITEM_H: u64 = 24
const MENU_ICON_SIZE: u64 = 16
const MAX_TASKBAR_ENTRIES = 20
const TASKBAR_NAME_LEN = 32
const TASKBAR_LABEL_LEN = 32
const START_HIT = -2
const TRAY_HIT = -3
const WINDOW_BUTTON_HIT_BASE = -100
const DESKTOP_ICON_W: i64 = 72
const DESKTOP_ICON_H: i64 = 58
const DESKTOP_ICON_LEFT: i64 = 18
const DESKTOP_ICON_TOP: i64 = 18
const DESKTOP_ICON_GAP_Y: i64 = 14
const DESKTOP_ICON_GAP_X: i64 = 12
const MAX_DESKTOP_ICONS: i64 = 8
const ICON_TERMINAL: u8 = 0
const ICON_FILE: u8 = 1
const ICON_APP: u8 = 2

let taskbar_names: u8[640] // MAX_TASKBAR_ENTRIES(20) * TASKBAR_NAME_LEN(32)
let taskbar_labels: u8[640] // MAX_TASKBAR_ENTRIES(20) * TASKBAR_LABEL_LEN(32)
let taskbar_icons: u8[20]
let taskbar_desktop: bool[20]
let desktop_apps: i64[8]
let desktop_count: i64 = 0
let taskbar_count: i64 = 0
let taskbar_loaded: bool = false
let start_menu_open: bool = false
let launcher_query: u8[24]
let launcher_query_len: i64 = 0
let wm_uptime_ms: u64 = 0
let wm_dirty: bool = true
let wm_frames_presented: u64 = 0
let wm_full_redraws: u64 = 0
let wm_rect_presents: u64 = 0
let wm_skipped_frames: u64 = 0
let cpu_history: u8[48]
let cpu_history_pos: i64 = 0
let cpu_last_total_ticks: u64 = 0
let cpu_last_idle_ticks: u64 = 0
let cpu_initialized: bool = false

const MAX_NOTIFICATIONS: i64 = 4
const NOTIFY_TITLE_LEN: i64 = 32
const NOTIFY_BODY_LEN: i64 = 64
const NOTIFY_TIMEOUT_MS: u64 = 6000
const NOTIFY_W: i64 = 286
const NOTIFY_H: i64 = 58
const NOTIFY_GAP: i64 = 8

let notify_used: bool[4]
let notify_created_ms: u64[4]
let notify_kind: u8[4]
let notify_titles: u8[128] // MAX_NOTIFICATIONS(4) * NOTIFY_TITLE_LEN(32)
let notify_bodies: u8[256] // MAX_NOTIFICATIONS(4) * NOTIFY_BODY_LEN(64)
let notify_unread: i64 = 0
let file_dialog_active: bool = false
let file_dialog_sender: u64 = 0
let file_dialog_owner_slot: i64 = -1
let file_dialog_selected: i64 = 0
const FILE_DIALOG_MAX_ROWS: i64 = 8
const APP_MANIFEST_PATH: u8* = "/etc/apps.txt" as u8*
const TASKBAR_PIN_LIMIT = 6
const SNAP_EDGE_PX: i64 = 24
const SNAP_HALF_PX: i64 = 36
const TASKBAR_DRAG_THRESHOLD: i64 = 10
let drag_file_active: bool = false
let drag_file_source: i64 = -1
let drag_file_path: u8[128]
let taskbar_drag_active: bool = false
let taskbar_drag_slot: i64 = -1
let taskbar_drag_start_x: i64 = 0
let taskbar_drag_start_y: i64 = 0
let taskbar_drag_target: i64 = -1
let pending_drop_valid: bool = false
let pending_drop_slot: i64 = -1
let pending_drop_path: u8[128]

func taskbar_name_at(i: i64) -> u8* {
    return (taskbar_names as u8*) + i * TASKBAR_NAME_LEN
}

func taskbar_label_at(i: i64) -> u8* {
    return (taskbar_labels as u8*) + i * TASKBAR_LABEL_LEN
}

func notify_title_at(i: i64) -> u8* {
    return (notify_titles as u8*) + i * NOTIFY_TITLE_LEN
}

func notify_body_at(i: i64) -> u8* {
    return (notify_bodies as u8*) + i * NOTIFY_BODY_LEN
}

func load_taskbar() {
    taskbar_count = 0
    desktop_count = 0
    let i: i64 = 0
    while i < MAX_TASKBAR_ENTRIES {
        taskbar_desktop[i] = false
        i = i + 1
    }
    if !load_app_manifest(APP_MANIFEST_PATH) {
        if !load_app_manifest("/boot/apps.txt" as u8*) {
            load_taskbar_dir("/bin" as u8*)
        }
    }
    if taskbar_count == 0 {
        load_taskbar_dir("/boot" as u8*)
    }
    rebuild_desktop_apps()
    taskbar_loaded = taskbar_count > 0
}

func has_elf_suffix(name: u8*) -> bool {
    let len: i64 = 0
    while name[len] != 0 {
        len = len + 1
    }
    if len < 4 {
        return false
    }
    return name[len - 4] == 46 && name[len - 3] == 101 && name[len - 2] == 108 && name[len - 1] == 102
}

func copy_fixed(dst: u8*, src: u8*, max_len: i64) {
    let j: i64 = 0
    while j < max_len - 1 && src[j] != 0 {
        dst[j] = src[j]
        j = j + 1
    }
    dst[j] = 0
    j = j + 1
    while j < max_len {
        dst[j] = 0
        j = j + 1
    }
}

func active_notification_count() -> i64 {
    let count: i64 = 0
    let i: i64 = 0
    while i < MAX_NOTIFICATIONS {
        if notify_used[i] {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

func expire_notifications() {
    let i: i64 = 0
    while i < MAX_NOTIFICATIONS {
        if notify_used[i] && wm_uptime_ms >= notify_created_ms[i] + NOTIFY_TIMEOUT_MS {
            notify_used[i] = false
        }
        i = i + 1
    }
}

func oldest_notification_slot() -> i64 {
    let slot: i64 = -1
    let oldest: u64 = 0
    let i: i64 = 0
    while i < MAX_NOTIFICATIONS {
        if !notify_used[i] {
            return i
        }
        if slot < 0 || notify_created_ms[i] < oldest {
            slot = i
            oldest = notify_created_ms[i]
        }
        i = i + 1
    }
    return slot
}

func add_notification(title: u8*, body: u8*, kind: u8) {
    let slot: i64 = oldest_notification_slot()
    if slot < 0 {
        return
    }
    notify_used[slot] = true
    notify_created_ms[slot] = wm_uptime_ms
    notify_kind[slot] = kind
    copy_fixed(notify_title_at(slot), title, NOTIFY_TITLE_LEN)
    copy_fixed(notify_body_at(slot), body, NOTIFY_BODY_LEN)
    notify_unread = notify_unread + 1
}

func app_icon_from_name(name: u8*) -> u8 {
    if name_starts_with(name, "terminal" as u8*) {
        return ICON_TERMINAL
    }
    if name_starts_with(name, "filebrowser" as u8*) || name_starts_with(name, "editor" as u8*) {
        return ICON_FILE
    }
    return ICON_APP
}

func icon_kind_from_field(field: u8*, fallback_name: u8*) -> u8 {
    if name_starts_with(field, "terminal" as u8*) {
        return ICON_TERMINAL
    }
    if name_starts_with(field, "file" as u8*) {
        return ICON_FILE
    }
    if name_starts_with(field, "app" as u8*) {
        return ICON_APP
    }
    return app_icon_from_name(fallback_name)
}

func append_app(exec_name: u8*, label: u8*, icon: u8, desktop: bool) {
    if taskbar_count >= MAX_TASKBAR_ENTRIES {
        return
    }
    let idx: i64 = taskbar_count
    copy_fixed(taskbar_name_at(idx), exec_name, TASKBAR_NAME_LEN)
    if label[0] == 0 {
        copy_fixed(taskbar_label_at(idx), exec_name, TASKBAR_LABEL_LEN)
    } else {
        copy_fixed(taskbar_label_at(idx), label, TASKBAR_LABEL_LEN)
    }
    taskbar_icons[idx] = icon
    taskbar_desktop[idx] = desktop
    if desktop && desktop_count < MAX_DESKTOP_ICONS {
        desktop_apps[desktop_count] = idx
        desktop_count = desktop_count + 1
    }
    taskbar_count = taskbar_count + 1
}

func rebuild_desktop_apps() {
    desktop_count = 0
    let i: i64 = 0
    while i < taskbar_count {
        if taskbar_desktop[i] && desktop_count < MAX_DESKTOP_ICONS {
            desktop_apps[desktop_count] = i
            desktop_count = desktop_count + 1
        }
        i = i + 1
    }
}

func manifest_icon_text(kind: u8) -> u8* {
    if kind == ICON_TERMINAL {
        return "terminal" as u8*
    }
    if kind == ICON_FILE {
        return "file" as u8*
    }
    return "app" as u8*
}

func save_taskbar_manifest() {
    let out: u8[2048]
    let pos: u64 = 0
    let i: i64 = 0
    while i < taskbar_count && pos + 64 < 2047 {
        let name: u8* = taskbar_name_at(i)
        let label: u8* = taskbar_label_at(i)
        let j: u64 = 0
        while name[j] != 0 && pos < 2047 {
            out[pos] = name[j]
            pos = pos + 1
            j = j + 1
        }
        if pos + 3 >= 2047 { break }
        out[pos] = 124
        pos = pos + 1
        j = 0
        while label[j] != 0 && pos < 2047 {
            out[pos] = label[j]
            pos = pos + 1
            j = j + 1
        }
        if pos + 3 >= 2047 { break }
        out[pos] = 124
        pos = pos + 1
        let icon_text: u8* = manifest_icon_text(taskbar_icons[i])
        j = 0
        while icon_text[j] != 0 && pos < 2047 {
            out[pos] = icon_text[j]
            pos = pos + 1
            j = j + 1
        }
        if pos + 2 >= 2047 { break }
        out[pos] = 124
        pos = pos + 1
        if taskbar_desktop[i] {
            out[pos] = 49
        } else {
            out[pos] = 48
        }
        pos = pos + 1
        out[pos] = 10
        pos = pos + 1
        i = i + 1
    }
    out[pos] = 0
    sys_write_all(APP_MANIFEST_PATH, out as u8*, pos)
}

func read_manifest_field(buf: u8*, pos_ptr: i64*, out: u8*, max_len: i64) -> u8 {
    let pos: i64 = pos_ptr[0]
    let n: i64 = 0
    while buf[pos] != 0 && buf[pos] != 124 && buf[pos] != 10 && buf[pos] != 13 {
        if n < max_len - 1 {
            out[n] = buf[pos]
            n = n + 1
        }
        pos = pos + 1
    }
    out[n] = 0
    let delim: u8 = buf[pos]
    if delim != 0 {
        pos = pos + 1
        if delim == 13 && buf[pos] == 10 {
            pos = pos + 1
        }
    }
    pos_ptr[0] = pos
    return delim
}

func skip_manifest_line(buf: u8*, pos_ptr: i64*) {
    let pos: i64 = pos_ptr[0]
    while buf[pos] != 0 && buf[pos] != 10 {
        pos = pos + 1
    }
    if buf[pos] == 10 {
        pos = pos + 1
    }
    pos_ptr[0] = pos
}

func parse_app_manifest(buf: u8*) -> bool {
    let pos: i64 = 0
    while buf[pos] != 0 && taskbar_count < MAX_TASKBAR_ENTRIES {
        let exec_name: u8[32]
        let label: u8[32]
        let icon_field: u8[16]
        let desktop_field: u8[8]

        let d: u8 = read_manifest_field(buf, &pos, exec_name as u8*, 32)
        if exec_name[0] == 0 {
            skip_manifest_line(buf, &pos)
        } else if d != 124 {
            skip_manifest_line(buf, &pos)
        } else {
            d = read_manifest_field(buf, &pos, label as u8*, 32)
            if d == 124 {
                d = read_manifest_field(buf, &pos, icon_field as u8*, 16)
            }
            if d == 124 {
                read_manifest_field(buf, &pos, desktop_field as u8*, 8)
            } else {
                desktop_field[0] = 48
                desktop_field[1] = 0
            }
            if has_elf_suffix(exec_name as u8*) {
                append_app(exec_name as u8*, label as u8*, icon_kind_from_field(icon_field as u8*, exec_name as u8*), desktop_field[0] == 49)
            }
        }
    }
    return taskbar_count > 0
}

func load_app_manifest(path: u8*) -> bool {
    let buf: u8[2048]
    let n: u64 = sys_read_all(path, buf as u8*, 2047)
    if n == RT_SYS_ERR || n == 0 {
        return false
    }
    buf[n] = 0
    return parse_app_manifest(buf as u8*)
}

func load_taskbar_dir(path: u8*) {
    taskbar_count = 0
    desktop_count = 0
    let i: u64 = 0
    let done: bool = false
    while (i as i64) < MAX_TASKBAR_ENTRIES && !done {
        let buf: u8[48]
        let ok: u64 = sys_readdir(path, i, buf as u8*)
        if ok == RT_SYS_ERR {
            done = true
        } else {
            let fields: u64* = ((buf as u8*) + 32) as u64*
            let kind: u64 = fields[0]
            if kind == 1 && has_elf_suffix(buf as u8*) { // VFS.KIND_FILE
                append_app(buf as u8*, buf as u8*, app_icon_from_name(buf as u8*), taskbar_count < 6)
            }
            i = i + 1
        }
    }
}

func draw_rect(x: i64, y: i64, w: i64, h: i64, color: u32) {
    if w <= 0 || h <= 0 {
        return
    }
    let row: i64 = 0
    while row < h {
        let col: i64 = 0
        while col < w {
            fb_put_pixel(x + col, y + row, color)
            col = col + 1
        }
        row = row + 1
    }
}

func draw_rect_border(x: i64, y: i64, w: i64, h: i64, color: u32) {
    if w <= 0 || h <= 0 {
        return
    }
    let col: i64 = 0
    while col < w {
        fb_put_pixel(x + col, y, color)
        fb_put_pixel(x + col, y + h - 1, color)
        col = col + 1
    }
    let row: i64 = 0
    while row < h {
        fb_put_pixel(x, y + row, color)
        fb_put_pixel(x + w - 1, y + row, color)
        row = row + 1
    }
}

func copy_short_label(dst: u8*, src: u8*, max_len: i64) {
    let k: i64 = 0
    while k < max_len - 1 && src[k] != 0 {
        dst[k] = src[k]
        k = k + 1
    }
    dst[k] = 0
}

func launcher_clear_query() {
    let i: i64 = 0
    while i < 23 {
        launcher_query[i] = 0
        i = i + 1
    }
    launcher_query_len = 0
}

func launcher_lower(c: u8) -> u8 {
    if c >= 65 && c <= 90 {
        return c + 32
    }
    return c
}

func launcher_contains(text: u8*, needle: u8*) -> bool {
    if needle[0] == 0 {
        return true
    }
    let i: i64 = 0
    while text[i] != 0 {
        let j: i64 = 0
        while needle[j] != 0 && text[i + j] != 0 && launcher_lower(text[i + j]) == launcher_lower(needle[j]) {
            j = j + 1
        }
        if needle[j] == 0 {
            return true
        }
        i = i + 1
    }
    return false
}

func launcher_matches(i: i64) -> bool {
    if launcher_query_len == 0 {
        return true
    }
    if launcher_contains(taskbar_label_at(i), launcher_query as u8*) {
        return true
    }
    return launcher_contains(taskbar_name_at(i), launcher_query as u8*)
}

func launcher_visible_count() -> i64 {
    let count: i64 = 0
    let i: i64 = 0
    while i < taskbar_count {
        if launcher_matches(i) {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

func launcher_taskbar_index_at(visible_index: i64) -> i64 {
    let seen: i64 = 0
    let i: i64 = 0
    while i < taskbar_count {
        if launcher_matches(i) {
            if seen == visible_index {
                return i
            }
            seen = seen + 1
        }
        i = i + 1
    }
    return -1
}

func launcher_launch_first() {
    let idx: i64 = launcher_taskbar_index_at(0)
    if idx >= 0 {
        taskbar_launch(idx)
    }
    start_menu_open = false
    launcher_clear_query()
}

func launcher_backspace() {
    if launcher_query_len <= 0 {
        return
    }
    launcher_query_len = launcher_query_len - 1
    launcher_query[launcher_query_len] = 0
}

func launcher_append(key: u64) {
    if key < 32 || key > 126 {
        return
    }
    if launcher_query_len >= 23 {
        return
    }
    launcher_query[launcher_query_len] = key as u8
    launcher_query_len = launcher_query_len + 1
    launcher_query[launcher_query_len] = 0
}

func launcher_key(key: u64) {
    if key == 8 {
        launcher_backspace()
        return
    }
    if key == 10 || key == 13 {
        launcher_launch_first()
        return
    }
    if key == KEY_ESC as u64 {
        if launcher_query_len > 0 {
            launcher_clear_query()
        } else {
            close_start_menu()
        }
        return
    }
    launcher_append(key)
}

func open_start_menu() {
    start_menu_open = true
    launcher_clear_query()
}

func close_start_menu() {
    start_menu_open = false
    launcher_clear_query()
}

func name_starts_with(name: u8*, prefix: u8*) -> bool {
    let i: i64 = 0
    while prefix[i] != 0 {
        if name[i] != prefix[i] {
            return false
        }
        i = i + 1
    }
    return true
}

func is_terminal_name(name: u8*) -> bool {
    return name_starts_with(name, "terminal" as u8*)
}

func icon_for_kind(kind: u8) -> EmbeddedImage {
    if kind == ICON_TERMINAL {
        return start_icon_terminal
    }
    if kind == ICON_FILE {
        return start_icon_file
    }
    return start_icon_app
}

func draw_embedded_icon(img: EmbeddedImage, x0: i64, y0: i64) {
    let y: u32 = 0
    while y < img.height {
        let x: u32 = 0
        while x < img.width {
            let alpha: u32 = get_pixel_alpha(img, x, y)
            if alpha != 0 {
                let px: i64 = x0 + (x as i64)
                let py: i64 = y0 + (y as i64)
                let fg: u32 = get_pixel(img, x, y)
                let bg: u32 = fb_get_pixel(px, py)
                fb_put_pixel(px, py, blend_alpha(fg, bg, alpha))
            }
            x = x + 1
        }
        y = y + 1
    }
}

func draw_embedded_icon_scaled(img: EmbeddedImage, x0: i64, y0: i64, scale: i64) {
    if scale <= 0 {
        return
    }
    let y: u32 = 0
    while y < img.height {
        let x: u32 = 0
        while x < img.width {
            let alpha: u32 = get_pixel_alpha(img, x, y)
            if alpha != 0 {
                let fg: u32 = get_pixel(img, x, y)
                let sy: i64 = 0
                while sy < scale {
                    let sx: i64 = 0
                    while sx < scale {
                        let px: i64 = x0 + (x as i64) * scale + sx
                        let py: i64 = y0 + (y as i64) * scale + sy
                        let bg: u32 = fb_get_pixel(px, py)
                        fb_put_pixel(px, py, blend_alpha(fg, bg, alpha))
                        sx = sx + 1
                    }
                    sy = sy + 1
                }
            }
            x = x + 1
        }
        y = y + 1
    }
}

func notification_color(kind: u8) -> u32 {
    if kind == 1 {
        return 0x2C4A32
    }
    if kind == 2 {
        return 0x5A3030
    }
    if kind == 3 {
        return 0x4A3E26
    }
    return 0x262A34
}

func draw_notification_icon(x: i64, y: i64, kind: u8, bg: u32) {
    let color: u32 = 0x9FD7FF
    let label: u8* = "i" as u8*
    if kind == 1 {
        color = 0x8EE090
        label = "+" as u8*
    } else if kind == 2 {
        color = 0xFF9090
        label = "!" as u8*
    } else if kind == 3 {
        color = 0xFFD060
        label = "*" as u8*
    }
    draw_rect(x, y, 18, 18, bg)
    draw_rect_border(x, y, 18, 18, color)
    wm_draw_string(x + 6, y + 2, label, color, bg)
}

func draw_notifications() {
    expire_notifications()
    let drawn: i64 = 0
    let newest: u64 = 0
    while drawn < MAX_NOTIFICATIONS {
        let slot: i64 = -1
        let i: i64 = 0
        while i < MAX_NOTIFICATIONS {
            if notify_used[i] && notify_created_ms[i] >= newest {
                if slot < 0 || notify_created_ms[i] < notify_created_ms[slot] {
                    slot = i
                }
            }
            i = i + 1
        }
        if slot < 0 {
            return
        }
        newest = notify_created_ms[slot] + 1
        let x: i64 = (fb_width as i64) - NOTIFY_W - 12
        let y: i64 = (fb_height as i64) - (TASKBAR_H as i64) - ((drawn + 1) * (NOTIFY_H + NOTIFY_GAP))
        if y >= 0 {
            let bg: u32 = notification_color(notify_kind[slot])
            draw_rect(x, y, NOTIFY_W, NOTIFY_H, bg)
            draw_rect_border(x, y, NOTIFY_W, NOTIFY_H, 0x707888)
            draw_notification_icon(x + 10, y + 10, notify_kind[slot], bg)
            wm_draw_string(x + 36, y + 9, notify_title_at(slot), 0xFFFFFF, bg)
            wm_draw_string(x + 36, y + 31, notify_body_at(slot), 0xD8D8D8, bg)
        }
        drawn = drawn + 1
    }
}

func write_two_digits(dst: u8*, pos: i64, value: i64) {
    dst[pos] = ((value / 10) + 48) as u8
    dst[pos + 1] = ((value % 10) + 48) as u8
}

func clock_label(dst: u8*) {
    let total_seconds: u64 = wm_uptime_ms / 1000
    let minutes: i64 = ((total_seconds / 60) % 100) as i64
    let seconds: i64 = (total_seconds % 60) as i64
    write_two_digits(dst, 0, minutes)
    dst[2] = 58 // ':'
    write_two_digits(dst, 3, seconds)
    dst[5] = 0
}

func tray_label(dst: u8*) {
    dst[0] = 78 // 'N'
    dst[1] = 32
    let count: i64 = notify_unread
    if count > 9 {
        count = 9
    }
    dst[2] = (48 + count) as u8
    dst[3] = 0
}

func update_cpu_graph_sample() {
    let info: u64[4]
    if sys_cpu_info(info as u64*) == RT_SYS_ERR {
        return
    }
    let total_ticks: u64 = info[0]
    let idle_ticks: u64 = info[1]
    if !cpu_initialized {
        cpu_last_total_ticks = total_ticks
        cpu_last_idle_ticks = idle_ticks
        cpu_initialized = true
        return
    }

    let total_delta: u64 = total_ticks - cpu_last_total_ticks
    let idle_delta: u64 = idle_ticks - cpu_last_idle_ticks
    cpu_last_total_ticks = total_ticks
    cpu_last_idle_ticks = idle_ticks

    let sample: u64 = 0
    if total_delta > 0 {
        let busy_delta: u64 = total_delta
        if idle_delta < total_delta {
            busy_delta = total_delta - idle_delta
        } else {
            busy_delta = 0
        }
        sample = (busy_delta * 100) / total_delta
    }
    cpu_history[cpu_history_pos] = sample as u8
    cpu_history_pos = cpu_history_pos + 1
    if cpu_history_pos >= CPU_GRAPH_SAMPLES {
        cpu_history_pos = 0
    }
}

func draw_cpu_graph(x: i64, y: i64) {
    draw_rect(x, y, CPU_GRAPH_W as i64, CPU_GRAPH_H as i64, 0x20242C)
    draw_rect_border(x, y, CPU_GRAPH_W as i64, CPU_GRAPH_H as i64, 0x505870)
    wm_draw_string(x + 5, y + 4, "CPU" as u8*, 0xA8D8FF, 0x20242C)

    let base_y: i64 = y + (CPU_GRAPH_H as i64) - 5
    let i: i64 = 0
    while i < CPU_GRAPH_SAMPLES {
        let idx: i64 = (cpu_history_pos + i) % CPU_GRAPH_SAMPLES
        let value: i64 = cpu_history[idx] as i64
        let bar_h: i64 = (value * 14) / 100
        let bx: i64 = x + 26 + i
        let by: i64 = base_y - bar_h
        let color: u32 = 0x75D17A
        if value > 75 {
            color = 0xF0C65A
        }
        if value > 92 {
            color = 0xF08C5A
        }
        let h: i64 = 0
        while h <= bar_h {
            fb_put_pixel(bx, by + h, color)
            h = h + 1
        }
        i = i + 1
    }
}

func window_taskbar_x(n: i64) -> i64 {
    return 92 + n * 78
}

func draw_window_taskbar_buttons(y0: i64, right_limit: i64) {
    let drawn: i64 = 0
    let slot: i64 = 0
    while slot < Wm.MAX_WINDOWS {
        if windows[slot].used {
            let x: i64 = window_taskbar_x(drawn)
            if x + 72 < right_limit {
                let bg: u32 = 0x303038
                if slot == focused && !windows[slot].minimized {
                    bg = 0x445070
                } else if windows[slot].minimized {
                    bg = 0x24242A
                }
                draw_rect(x, y0 + 5, 72, (TASKBAR_H as i64) - 10, bg)
                draw_rect_border(x, y0 + 5, 72, (TASKBAR_H as i64) - 10, 0x606070)
                wm_draw_string(x + 8, y0 + 9, windows[slot].title as u8*, TASKBAR_TEXT, bg)
            }
            drawn = drawn + 1
        }
        slot = slot + 1
    }
}

func hit_test_window_taskbar(mx: i64, my: i64, right_limit: i64) -> i64 {
    if fb_height <= TASKBAR_H {
        return -1
    }
    let y0: i64 = (fb_height as i64) - (TASKBAR_H as i64)
    if my < y0 + 5 || my >= y0 + (TASKBAR_H as i64) - 5 {
        return -1
    }
    let drawn: i64 = 0
    let slot: i64 = 0
    while slot < Wm.MAX_WINDOWS {
        if windows[slot].used {
            let x: i64 = window_taskbar_x(drawn)
            if x + 72 < right_limit && mx >= x && mx < x + 72 {
                return slot
            }
            drawn = drawn + 1
        }
        slot = slot + 1
    }
    return -1
}

func file_dialog_entry_count() -> i64 {
    let count: i64 = 0
    let entry: u8[48]
    while count < 48 && sys_readdir("/" as u8*, count as u64, entry as u8*) != RT_SYS_ERR {
        count = count + 1
    }
    return count
}

func file_dialog_entry_at(index: i64, out: u8*) -> bool {
    let entry: u8[48]
    if sys_readdir("/" as u8*, index as u64, entry as u8*) == RT_SYS_ERR {
        return false
    }
    let i: i64 = 0
    while i < 31 && entry[i] != 0 {
        out[i] = entry[i]
        i = i + 1
    }
    out[i] = 0
    return true
}

func file_dialog_reply(ok: bool) {
    let reply: u8[128]
    let r: u64* = (reply as u8*) as u64*
    if ok {
        r[0] = Wm.STATUS_OK as u64
    } else {
        r[0] = Wm.STATUS_FAIL as u64
    }
    sys_msg_reply(file_dialog_sender, reply as u8*, 128)
    file_dialog_active = false
    file_dialog_sender = 0
    file_dialog_owner_slot = -1
    file_dialog_selected = 0
    wm_dirty = true
}

func file_dialog_accept() {
    let name: u8[32]
    if !file_dialog_entry_at(file_dialog_selected, name as u8*) {
        file_dialog_reply(false)
        return
    }
    let reply: u8[128]
    let r: u64* = (reply as u8*) as u64*
    r[0] = Wm.STATUS_OK as u64
    let out: u8* = (reply as u8*) + 8
    out[0] = 47
    let i: i64 = 0
    while i < 94 && name[i] != 0 {
        out[i + 1] = name[i]
        i = i + 1
    }
    out[i + 1] = 0
    sys_msg_reply(file_dialog_sender, reply as u8*, 128)
    file_dialog_active = false
    file_dialog_sender = 0
    file_dialog_owner_slot = -1
    file_dialog_selected = 0
    wm_dirty = true
}

func file_dialog_key(key: u64) {
    let count: i64 = file_dialog_entry_count()
    if key == (KEY_ESC as u64) || key == (KEY_CLOSE_REQ as u64) {
        file_dialog_reply(false)
    } else if key == (KEY_UP as u64) {
        if file_dialog_selected > 0 {
            file_dialog_selected = file_dialog_selected - 1
            wm_dirty = true
        }
    } else if key == (KEY_DOWN as u64) {
        if file_dialog_selected < count - 1 {
            file_dialog_selected = file_dialog_selected + 1
            wm_dirty = true
        }
    } else if key == 10 {
        if count > 0 {
            file_dialog_accept()
        } else {
            file_dialog_reply(false)
        }
    }
}

func draw_file_dialog() {
    if !file_dialog_active {
        return
    }
    let box_w: i64 = 300
    let box_h: i64 = 166
    let x: i64 = ((fb_width as i64) - box_w) / 2
    let y: i64 = ((fb_height as i64) - (TASKBAR_H as i64) - box_h) / 2
    draw_rect(x, y, box_w, box_h, 0x20202A)
    draw_rect_border(x, y, box_w, box_h, 0x707080)
    wm_draw_string(x + 12, y + 10, "Open file" as u8*, TASKBAR_TEXT, 0x20202A)
    wm_draw_string(x + 190, y + 10, "Enter / Esc" as u8*, 0xB8B8C8, 0x20202A)

    let count: i64 = file_dialog_entry_count()
    let top: i64 = 0
    if file_dialog_selected >= FILE_DIALOG_MAX_ROWS {
        top = file_dialog_selected - FILE_DIALOG_MAX_ROWS + 1
    }
    let row: i64 = 0
    while row < FILE_DIALOG_MAX_ROWS {
        let idx: i64 = top + row
        let ry: i64 = y + 34 + row * 16
        let bg: u32 = 0x262630
        if idx == file_dialog_selected {
            bg = 0x3A5378
        }
        draw_rect(x + 10, ry, box_w - 20, 14, bg)
        if idx < count {
            let name: u8[32]
            if file_dialog_entry_at(idx, name as u8*) {
                wm_draw_string(x + 18, ry + 2, name as u8*, TASKBAR_TEXT, bg)
            }
        }
        row = row + 1
    }
}

func draw_start_menu(y0: i64) {
    if !start_menu_open {
        return
    }
    let visible_count: i64 = launcher_visible_count()
    let menu_items_h: i64 = MENU_ITEM_H as i64
    if visible_count > 0 {
        menu_items_h = visible_count * (MENU_ITEM_H as i64)
    }
    let menu_h: i64 = 36 + menu_items_h
    let menu_y: i64 = y0 - menu_h
    let safe_y: i64 = menu_y
    if safe_y < 0 {
        safe_y = 0
    }
    draw_rect(8, safe_y, MENU_W as i64, y0 - safe_y, 0x202028)
    draw_rect_border(8, safe_y, MENU_W as i64, y0 - safe_y, 0x686878)

    draw_rect(12, safe_y + 8, (MENU_W as i64) - 16, 18, 0x2A2A34)
    draw_rect_border(12, safe_y + 8, (MENU_W as i64) - 16, 18, 0x707080)
    if launcher_query_len == 0 {
        wm_draw_string(18, safe_y + 12, "Search apps" as u8*, 0x808894, 0x2A2A34)
    } else {
        wm_draw_string(18, safe_y + 12, launcher_query as u8*, TASKBAR_TEXT, 0x2A2A34)
    }

    let item_top: i64 = safe_y + 32
    let i: i64 = 0
    let shown: i64 = 0
    while i < taskbar_count {
        if launcher_matches(i) {
            let iy: i64 = item_top + shown * (MENU_ITEM_H as i64)
            if iy >= safe_y && iy + (MENU_ITEM_H as i64) <= y0 {
                draw_rect(12, iy, (MENU_W as i64) - 8, (MENU_ITEM_H as i64) - 2, 0x30303A)
                let icon: EmbeddedImage = icon_for_kind(taskbar_icons[i])
                draw_embedded_icon(icon, 18, iy + 3)
                let label: u8[19]
                copy_short_label(label as u8*, taskbar_label_at(i), 18)
                wm_draw_string(40, iy + 4, label as u8*, TASKBAR_TEXT, 0x30303A)
            }
            shown = shown + 1
        }
        i = i + 1
    }
    if shown == 0 {
        wm_draw_string(18, item_top + 2, "No results" as u8*, 0x808894, 0x202028)
    }
}

func draw_taskbar() {
    if fb_width == 0 || fb_height <= TASKBAR_H {
        return
    }
    if !taskbar_loaded {
        load_taskbar()
    }
    let y0: i64 = (fb_height as i64) - (TASKBAR_H as i64)

    // Draw taskbar background with subtle gradient effect
    let row: i64 = 0
    while row < (TASKBAR_H as i64) {
        let col: i64 = 0
        // Create a very subtle gradient by slightly darkening the top
        let shade: i64 = (TASKBAR_BG as i64) - (row * 2)
        let taskbar_color: u32 = shade as u32
        while col < (fb_width as i64) {
            fb_put_pixel(col, y0 + row, taskbar_color)
            col = col + 1
        }
        row = row + 1
    }

    // Draw a subtle separator line at the top of the taskbar
    let sep_col: i64 = 0
    while sep_col < (fb_width as i64) {
        fb_put_pixel(sep_col, y0, 0x505050)
        sep_col = sep_col + 1
    }

    draw_rect(8, y0 + 4, START_BTN_W as i64, (TASKBAR_H as i64) - 8, TASKBAR_BTN)
    draw_rect_border(8, y0 + 4, START_BTN_W as i64, (TASKBAR_H as i64) - 8, 0x707070)
    wm_draw_string(18, y0 + 8, "Start" as u8*, TASKBAR_TEXT, TASKBAR_BTN)

    let clock_x: i64 = (fb_width as i64) - (CLOCK_W as i64) - 8
    let tray_x: i64 = clock_x - (TRAY_W as i64) - 6
    let cpu_x: i64 = tray_x - (CPU_GRAPH_W as i64) - 6
    draw_window_taskbar_buttons(y0, cpu_x - 6)

    let clock: u8[6]
    clock_label(clock as u8*)
    draw_rect(clock_x, y0 + 4, CLOCK_W as i64, (TASKBAR_H as i64) - 8, 0x24242A)
    draw_rect_border(clock_x, y0 + 4, CLOCK_W as i64, (TASKBAR_H as i64) - 8, 0x505050)
    wm_draw_string(clock_x + 12, y0 + 8, clock as u8*, TASKBAR_TEXT, 0x24242A)

    let tray_bg: u32 = 0x242832
    if notify_unread > 0 {
        tray_bg = 0x30384A
    }
    draw_rect(tray_x, y0 + 4, TRAY_W as i64, (TASKBAR_H as i64) - 8, tray_bg)
    draw_rect_border(tray_x, y0 + 4, TRAY_W as i64, (TASKBAR_H as i64) - 8, 0x505870)
    draw_rect(tray_x + 8, y0 + 11, 8, 8, 0x8ED0FF)
    draw_rect_border(tray_x + 8, y0 + 11, 8, 8, 0xD8F0FF)
    let tray: u8[4]
    tray_label(tray as u8*)
    wm_draw_string(tray_x + 22, y0 + 8, tray as u8*, TASKBAR_TEXT, tray_bg)

    draw_cpu_graph(cpu_x, y0 + 4)

    draw_start_menu(y0)
}

// START_HIT toggles the menu; non-negative values launch an item from the
// open menu; -1 means no taskbar action.
func hit_test_taskbar(mx: i64, my: i64) -> i64 {
    if fb_width == 0 || fb_height <= TASKBAR_H {
        return -1
    }
    let y0: i64 = (fb_height as i64) - (TASKBAR_H as i64)
    if my >= y0 {
        if mx >= 8 && mx < 8 + (START_BTN_W as i64) {
            return START_HIT
        }
        let clock_x: i64 = (fb_width as i64) - (CLOCK_W as i64) - 8
        let tray_x: i64 = clock_x - (TRAY_W as i64) - 6
        let cpu_x: i64 = tray_x - (CPU_GRAPH_W as i64) - 6
        let win_hit: i64 = hit_test_window_taskbar(mx, my, cpu_x - 6)
        if win_hit >= 0 {
            return WINDOW_BUTTON_HIT_BASE - win_hit
        }
        if mx >= tray_x && mx < tray_x + (TRAY_W as i64) {
            return TRAY_HIT
        }
        return -1
    }

    if start_menu_open {
        let visible_count: i64 = launcher_visible_count()
        let menu_items_h: i64 = MENU_ITEM_H as i64
        if visible_count > 0 {
            menu_items_h = visible_count * (MENU_ITEM_H as i64)
        }
        let menu_h: i64 = 36 + menu_items_h
        let menu_y: i64 = y0 - menu_h
        let safe_y: i64 = menu_y
        if safe_y < 0 {
            safe_y = 0
        }
        if mx >= 8 && mx < 8 + (MENU_W as i64) && my >= safe_y && my < y0 {
            let item_top: i64 = safe_y + 32
            if my >= item_top {
                let idx: i64 = (my - item_top) / (MENU_ITEM_H as i64)
                if idx >= 0 && idx < visible_count {
                    return launcher_taskbar_index_at(idx)
                }
            }
        }
    }
    return -1
}

func launch_fresh_terminal() {
    let handle: u64 = sys_spawn("/boot/terminal.elf" as u8*, "--gui-new" as u8*)
    if handle == RT_SYS_ERR {
        let fallback: u64 = sys_spawn("/bin/terminal.elf" as u8*, "--gui-new" as u8*)
        if fallback == RT_SYS_ERR {
            add_notification("Launch failed" as u8*, "Terminal executable was not found" as u8*, 2)
        } else {
            add_notification("Terminal launched" as u8*, "Started a fresh shell window" as u8*, 1)
        }
    } else {
        add_notification("Terminal launched" as u8*, "Started a fresh shell window" as u8*, 1)
    }
}

func build_launch_path(dst: u8*, prefix: u8*, name: u8*) {
    let i: i64 = 0
    while prefix[i] != 0 && i < 47 {
        dst[i] = prefix[i]
        i = i + 1
    }
    let j: i64 = 0
    while name[j] != 0 && i < 47 {
        dst[i] = name[j]
        i = i + 1
        j = j + 1
    }
    dst[i] = 0
}

func launch_app_name(name: u8*) {
    if is_terminal_name(name) {
        launch_fresh_terminal()
        return
    }
    let path: u8[48]
    build_launch_path(path as u8*, "/bin/" as u8*, name)
    let handle: u64 = sys_spawn(path as u8*, "")
    if handle == RT_SYS_ERR {
        build_launch_path(path as u8*, "/boot/" as u8*, name)
        let boot_handle: u64 = sys_spawn(path as u8*, "")
        if boot_handle == RT_SYS_ERR {
            add_notification("Launch failed" as u8*, name, 2)
        } else {
            add_notification("App launched" as u8*, name, 1)
        }
    } else {
        add_notification("App launched" as u8*, name, 1)
    }
}

func taskbar_launch(i: i64) {
    launch_app_name(taskbar_name_at(i))
}

func swap_taskbar_entries(a: i64, b: i64) {
    if a == b || a < 0 || b < 0 || a >= taskbar_count || b >= taskbar_count {
        return
    }
    let name_a: u8[32]
    let name_b: u8[32]
    let label_a: u8[32]
    let label_b: u8[32]
    let i: i64 = 0
    while i < 32 {
        name_a[i] = taskbar_name_at(a)[i]
        name_b[i] = taskbar_name_at(b)[i]
        label_a[i] = taskbar_label_at(a)[i]
        label_b[i] = taskbar_label_at(b)[i]
        i = i + 1
    }
    let icon_a: u8 = taskbar_icons[a]
    let icon_b: u8 = taskbar_icons[b]
    let desk_a: bool = taskbar_desktop[a]
    let desk_b: bool = taskbar_desktop[b]
    i = 0
    while i < 32 {
        taskbar_name_at(a)[i] = name_b[i]
        taskbar_name_at(b)[i] = name_a[i]
        taskbar_label_at(a)[i] = label_b[i]
        taskbar_label_at(b)[i] = label_a[i]
        i = i + 1
    }
    taskbar_icons[a] = icon_b
    taskbar_icons[b] = icon_a
    taskbar_desktop[a] = desk_b
    taskbar_desktop[b] = desk_a
}

func toggle_taskbar_pin(slot: i64) {
    if slot < 0 || slot >= taskbar_count {
        return
    }
    taskbar_desktop[slot] = !taskbar_desktop[slot]
    rebuild_desktop_apps()
    save_taskbar_manifest()
    wm_dirty = true
}

func reorder_taskbar_button(slot: i64, target: i64) {
    if slot < 0 || target < 0 || slot >= taskbar_count || target >= taskbar_count {
        return
    }
    if slot == target {
        return
    }
    let cur: i64 = slot
    let step: i64 = 1
    if target < slot {
        let t: i64 = target
        while cur > t {
            swap_taskbar_entries(cur, cur - 1)
            cur = cur - 1
        }
    } else {
        while cur < target {
            swap_taskbar_entries(cur, cur + 1)
            cur = cur + 1
        }
    }
    rebuild_desktop_apps()
    save_taskbar_manifest()
    wm_dirty = true
}

func desktop_icon_name(i: i64) -> u8* {
    return taskbar_name_at(desktop_apps[i])
}

func desktop_icon_label(i: i64) -> u8* {
    return taskbar_label_at(desktop_apps[i])
}

func desktop_icon_image(i: i64) -> EmbeddedImage {
    return icon_for_kind(taskbar_icons[desktop_apps[i]])
}

func desktop_icons_per_column() -> i64 {
    let usable_h: i64 = (fb_height as i64) - (TASKBAR_H as i64) - DESKTOP_ICON_TOP
    let stride: i64 = DESKTOP_ICON_H + DESKTOP_ICON_GAP_Y
    let n: i64 = usable_h / stride
    if n < 1 {
        return 1
    }
    return n
}

func desktop_icon_x(i: i64) -> i64 {
    let per_col: i64 = desktop_icons_per_column()
    let col: i64 = i / per_col
    return DESKTOP_ICON_LEFT + col * (DESKTOP_ICON_W + DESKTOP_ICON_GAP_X)
}

func desktop_icon_y(i: i64) -> i64 {
    let per_col: i64 = desktop_icons_per_column()
    let row: i64 = i % per_col
    return DESKTOP_ICON_TOP + row * (DESKTOP_ICON_H + DESKTOP_ICON_GAP_Y)
}

func point_in_any_window(mx: i64, my: i64) -> bool {
    let i: i64 = 0
    while i < Wm.MAX_WINDOWS {
        if windows[i].used && !windows[i].minimized {
            let ox: i64 = windows[i].win_x as i64
            let oy: i64 = windows[i].win_y as i64
            let vw: i64 = windows[i].vis_w as i64
            let vh: i64 = (windows[i].vis_h as i64) + (TITLEBAR_H as i64)
            if mx >= ox && mx < ox + vw && my >= oy && my < oy + vh {
                return true
            }
        }
        i = i + 1
    }
    return false
}

func hit_test_desktop_icon(mx: i64, my: i64) -> i64 {
    if fb_width == 0 || fb_height <= TASKBAR_H {
        return -1
    }
    if my >= (fb_height as i64) - (TASKBAR_H as i64) {
        return -1
    }
    if point_in_any_window(mx, my) {
        return -1
    }
    let i: i64 = 0
    while i < desktop_count {
        let x: i64 = desktop_icon_x(i)
        let y: i64 = desktop_icon_y(i)
        if mx >= x && mx < x + DESKTOP_ICON_W && my >= y && my < y + DESKTOP_ICON_H {
            return i
        }
        i = i + 1
    }
    return -1
}

func draw_desktop_icons(mouse_x: i64, mouse_y: i64) {
    let hover: i64 = hit_test_desktop_icon(mouse_x, mouse_y)
    let i: i64 = 0
    while i < desktop_count {
        let x: i64 = desktop_icon_x(i)
        let y: i64 = desktop_icon_y(i)
        let bg: u32 = 0x181820
        if i == hover {
            bg = 0x30384A
            draw_rect(x, y, DESKTOP_ICON_W, DESKTOP_ICON_H, bg)
            draw_rect_border(x, y, DESKTOP_ICON_W, DESKTOP_ICON_H, 0x6A7898)
        }
        let icon: EmbeddedImage = desktop_icon_image(i)
        draw_embedded_icon_scaled(icon, x + 20, y + 5, 2)
        draw_rect(x + 2, y + 41, DESKTOP_ICON_W - 4, 12, bg)
        wm_draw_string(x + 4, y + 43, desktop_icon_label(i), TASKBAR_TEXT, bg)
        i = i + 1
    }
}

func desktop_icon_launch(i: i64) {
    launch_app_name(desktop_icon_name(i))
}

func hit_test_window_under_point(mx: i64, my: i64) -> i64 {
    let zi: i64 = z_count - 1
    while zi >= 0 {
        let slot: i64 = z_order[zi]
        if windows[slot].used && !windows[slot].minimized {
            let ox: i64 = windows[slot].win_x as i64
            let oy: i64 = windows[slot].win_y as i64
            let vw: i64 = windows[slot].vis_w as i64
            let vh: i64 = (windows[slot].vis_h as i64) + (TITLEBAR_H as i64)
            if mx >= ox && mx < ox + vw && my >= oy && my < oy + vh {
                return slot
            }
        }
        zi = zi - 1
    }
    return -1
}

func begin_file_drag(slot: i64, path: u8*) {
    if slot < 0 || slot >= Wm.MAX_WINDOWS {
        return
    }
    let i: i64 = 0
    while i < 127 && path[i] != 0 {
        drag_file_path[i] = path[i]
        i = i + 1
    }
    drag_file_path[i] = 0
    drag_file_source = slot
    drag_file_active = true
}

func queue_file_drop(target_slot: i64) {
    if !drag_file_active || target_slot < 0 || target_slot >= Wm.MAX_WINDOWS || !windows[target_slot].used {
        drag_file_active = false
        drag_file_source = -1
        return
    }
    if target_slot == drag_file_source {
        drag_file_active = false
        drag_file_source = -1
        return
    }
    pending_drop_valid = true
    pending_drop_slot = target_slot
    let i: i64 = 0
    while i < 127 && drag_file_path[i] != 0 {
        pending_drop_path[i] = drag_file_path[i]
        i = i + 1
    }
    pending_drop_path[i] = 0
    drag_file_active = false
    drag_file_source = -1
}

// Full repaint of windows + cursor (shadows, decoration, then content,
// then the cursor on top of everything) rather than any kind of dirty-rect
// tracking - cheap enough (a handful of 320x200-ish window blits) to just
// do unconditionally every active tick, same as fill_backdrop now is.
// Windows are drawn in z-order (back to front) so clicks properly bring
// windows to the front, and so each one's semi-transparent blend (see
// WINDOW_ALPHA) sees whatever's already been composited behind it -
// the backdrop, or any window further back in z-order.
func redraw_windows(mouse_x: i64, mouse_y: i64) {
    draw_desktop_icons(mouse_x, mouse_y)

    // First pass: draw all shadows in z-order
    let i: i64 = 0
    while i < z_count {
        let slot: i64 = z_order[i]
        if windows[slot].used && !windows[slot].minimized {
            draw_shadow(slot)
        }
        i = i + 1
    }

    // Second pass: draw windows on top of shadows in z-order
    i = 0
    while i < z_count {
        let slot: i64 = z_order[i]
        if windows[slot].used && !windows[slot].minimized {
            draw_titlebar(slot)
            blit_window(slot)
            draw_window_border(slot)
            draw_resize_grip(slot)
        }
        i = i + 1
    }
    draw_file_dialog()
    draw_taskbar()
    draw_notifications()
    draw_cursor(mouse_x, mouse_y)
}

// The only thing that ever touches the real framebuffer: one bulk copy
// of the fully-composited back buffer, once per tick, after everything
// above has already finished drawing into it. 8 bytes (a whole u64) at
// a time rather than byte-by-byte - there's no faster bulk-copy
// primitive exposed to ring-3 code in this kernel (sys_memcpy/
// llpl_memcpy are both plain byte loops), and a ~3MB frame at a
// real resolution adds up fast: this alone is an 8x reduction in loop
// iterations over the naive version.
func present_frame() {
    wm_frames_presented = wm_frames_presented + 1
    let total_bytes: u64 = fb_pitch * fb_height
    let total_words: u64 = total_bytes / 8
    let src: u64* = backbuf as u64*
    let dst: u64* = fb as u64*
    let i: u64 = 0
    while i < total_words {
        dst[i] = src[i]
        i = i + 1
    }
    // Any trailing bytes that don't make a whole word (shouldn't happen
    // for a real pitch/height, but costs nothing to handle correctly).
    let done: u64 = total_words * 8
    let rem: u64 = total_bytes - done
    let src_tail: u8* = backbuf + done
    let dst_tail: u8* = fb + done
    let j: u64 = 0
    while j < rem {
        dst_tail[j] = src_tail[j]
        j = j + 1
    }
}

// Shared dispatch for both the pre-active (blocking recv) and active
// (non-blocking try_recv + redraw ticking) phases of the main loop below
// - the request/reply shape a client sees is identical either way, only
// how a message gets picked up differs.
func handle_request(sender: u64, msg: u8*) {
    let req: u64* = (msg as u8*) as u64*
    let op: u64 = req[0]
    let slot_arg: i64 = req[1] as i64

    let reply: u8[128]
    let rep: u64* = (reply as u8*) as u64*

    if op == (Wm.OP_CREATE as u64) {
        let slot: i64 = find_free_slot()
        if slot < 0 {
            rep[0] = Wm.STATUS_FAIL as u64
            sys_msg_reply(sender, reply as u8*, 8)
        } else {
            windows[slot].used = true
            windows[slot].owner_pid = sender as i64
            windows[slot].win_x = initial_window_x(slot)
            windows[slot].win_y = initial_window_y(slot)
            windows[slot].vis_w = DEFAULT_VIS_W
            windows[slot].vis_h = DEFAULT_VIS_H
            if windows[slot].vis_w > (max_visible_w_for(slot) as u64) {
                windows[slot].vis_w = max_visible_w_for(slot) as u64
            }
            if windows[slot].vis_h > (max_visible_h_for(slot) as u64) {
                windows[slot].vis_h = max_visible_h_for(slot) as u64
            }
            windows[slot].restore_x = windows[slot].win_x
            windows[slot].restore_y = windows[slot].win_y
            windows[slot].restore_w = windows[slot].vis_w
            windows[slot].restore_h = windows[slot].vis_h
            windows[slot].minimized = false
            windows[slot].maximized = false
            windows[slot].close_requested = false

            // Set default window title
            let title_prefix: u8* = "Window " as u8*
            let j: i64 = 0
            while title_prefix[j] != 0 && j < 31 {
                windows[slot].title[j] = title_prefix[j]
                j = j + 1
            }
            // Add slot number
            windows[slot].title[j] = (48 + slot) as u8
            windows[slot].title[j + 1] = 0
            // Unconditional, not just "if nothing else is focused yet" -
            // a newly created window should always grab focus the same
            // way opening a file in any real desktop both opens *and*
            // focuses it. The old "only if focused < 0" version left
            // every window opened after the first one sitting there
            // unfocused (silently discarding all keyboard input - see
            // OP_POLL_INPUT below) until the user noticed and pressed
            // TAB or clicked its titlebar - easy to miss, and looks
            // exactly like "this program doesn't respond to the
            // keyboard" rather than "this program just isn't focused".
            focused = slot
            // Add to z-order at the front (newly created windows appear on top)
            z_add(slot)
            active = true
            wm_dirty = true
            rep[0] = Wm.STATUS_OK as u64
            rep[1] = slot as u64
            rep[2] = (slot as u64) * Wm.WIN_BYTES
            rep[3] = windows[slot].win_x
            rep[4] = windows[slot].win_y
            sys_msg_reply(sender, reply as u8*, 40)
        }
    } else if op == (Wm.OP_PRESENT as u64) {
        if slot_arg >= 0 && slot_arg < Wm.MAX_WINDOWS && windows[slot_arg].used {
            wm_dirty = true
            rep[0] = Wm.STATUS_OK as u64
        } else {
            rep[0] = Wm.STATUS_FAIL as u64
        }
        sys_msg_reply(sender, reply as u8*, 8)
    } else if op == (Wm.OP_PRESENT_RECT as u64) {
        if slot_arg >= 0 && slot_arg < Wm.MAX_WINDOWS && windows[slot_arg].used {
            let rx: i64 = req[2] as i64
            let ry: i64 = req[3] as i64
            let rw: i64 = req[4] as i64
            let rh: i64 = req[5] as i64
            wm_rect_presents = wm_rect_presents + 1
            present_window_rect(slot_arg, rx, ry, rw, rh)
            rep[0] = Wm.STATUS_OK as u64
        } else {
            rep[0] = Wm.STATUS_FAIL as u64
        }
        sys_msg_reply(sender, reply as u8*, 8)
    } else if op == (Wm.OP_POLL_INPUT as u64) {
        // STATUS_FAIL whenever this slot isn't a live window of the
        // caller's own - a client only ever ends up here by calling
        // OP_CLOSE itself (the close button no longer force-removes a
        // window out from under its client - see close_requested's own
        // doc comment on Window), so in practice this now means "you
        // already closed yourself and polled again anyway", not "you've
        // been closed without warning". Kept as a defensive backstop
        // regardless (wm_client.llpl's wm_poll_input still treats it as
        // exit-worthy): better to stop cleanly than spin forever polling
        // a slot nothing will ever composite again.
        if slot_arg < 0 || slot_arg >= Wm.MAX_WINDOWS || !windows[slot_arg].used {
            rep[0] = Wm.STATUS_FAIL as u64
            rep[1] = 0
            rep[2] = 0
            rep[3] = 0
            rep[4] = 0
            rep[5] = 0
            rep[6] = 0
            rep[7] = 0
            sys_msg_reply(sender, reply as u8*, 64)
        } else if windows[slot_arg].close_requested {
            // Checked before the focus-gated keyboard poll below, and
            // regardless of focus - the close button applies to a
            // specific window, not to whichever one is currently
            // listening for keys, so an unfocused window still needs to
            // learn about its own close request on its very next poll.
            windows[slot_arg].close_requested = false
            rep[0] = Wm.STATUS_OK as u64
            rep[1] = KEY_CLOSE_REQ as u64
            rep[2] = 0
            rep[3] = 0
            rep[4] = 0
            rep[5] = 0
            rep[6] = windows[slot_arg].vis_w
            rep[7] = windows[slot_arg].vis_h
            sys_msg_reply(sender, reply as u8*, 64)
        } else {
            let key: u64 = 0
            let wheel: i64 = 0
            if slot_arg == focused {
                if !start_menu_open {
                    key = sys_kbd_poll()
                    if key == 9 {
                        let nxt: i64 = next_focus_after(focused)
                        if nxt >= 0 {
                            focused = nxt
                        }
                        key = 0
                    }
                } else {
                    key = 0
                }
                // Only the focused window ever receives wheel motion too
                // (same reasoning as keyboard focus - see this file's
                // header comment - a background window scrolling out
                // from under whatever's on top would be just as
                // confusing as it stealing keystrokes would be), and
                // it's handed off (reset to 0) here rather than left for
                // some other slot to see stale leftovers from.
                wheel = wheel_accum
                wheel_accum = 0
            }

            // Convert global mouse position to window-relative coordinates
            let win_x: i64 = windows[slot_arg].win_x as i64
            let win_y: i64 = windows[slot_arg].win_y as i64
            let rel_x: i64 = global_mouse_x - win_x
            let rel_y: i64 = global_mouse_y - win_y - (TITLEBAR_H as i64)

            // Clamp to window bounds
            if rel_x < 0 { rel_x = -1 }
            if rel_y < 0 { rel_y = -1 }
            if rel_x >= (windows[slot_arg].vis_w as i64) { rel_x = -1 }
            if rel_y >= (windows[slot_arg].vis_h as i64) { rel_y = -1 }

            let mouse_flags: u64 = 0
            if global_mouse_left { mouse_flags = mouse_flags | 1 }
            if global_mouse_right { mouse_flags = mouse_flags | 2 }

            rep[0] = Wm.STATUS_OK as u64
            rep[1] = key
            rep[2] = wheel as u64
            rep[3] = rel_x as u64
            rep[4] = rel_y as u64
            rep[5] = mouse_flags
            rep[6] = windows[slot_arg].vis_w
            rep[7] = windows[slot_arg].vis_h
            rep[8] = 0
            if pending_drop_valid && pending_drop_slot == slot_arg {
                rep[8] = 1
                let di: i64 = 0
                while di < 127 && pending_drop_path[di] != 0 {
                    reply[72 + di] = pending_drop_path[di]
                    di = di + 1
                }
                reply[72 + di] = 0
                pending_drop_valid = false
                pending_drop_slot = -1
            }
            sys_msg_reply(sender, reply as u8*, 80)
        }
    } else if op == (Wm.OP_CLOSE as u64) {
        if slot_arg >= 0 && slot_arg < Wm.MAX_WINDOWS {
            windows[slot_arg].used = false
            windows[slot_arg].minimized = false
            windows[slot_arg].maximized = false
            windows[slot_arg].owner_pid = -1
            // Remove from z-order
            z_remove(slot_arg)
            if focused == slot_arg {
                focused = next_focus_after(slot_arg)
            }
            wm_dirty = true
        }
        rep[0] = Wm.STATUS_OK as u64
        sys_msg_reply(sender, reply as u8*, 8)
    } else if op == (Wm.OP_NOTIFY as u64) {
        let kind: u64 = req[1]
        if kind > 3 {
            kind = 0
        }
        add_notification((msg as u8*) + 16, (msg as u8*) + 48, kind as u8)
        wm_dirty = true
        rep[0] = Wm.STATUS_OK as u64
        sys_msg_reply(sender, reply as u8*, 8)
    } else if op == (Wm.OP_FILE_DIALOG as u64) {
        if !file_dialog_active && slot_arg >= 0 && slot_arg < Wm.MAX_WINDOWS && windows[slot_arg].used {
            file_dialog_active = true
            file_dialog_sender = sender
            file_dialog_owner_slot = slot_arg
            file_dialog_selected = 0
            focused = slot_arg
            z_bring_to_front(slot_arg)
            wm_dirty = true
        } else {
            rep[0] = Wm.STATUS_FAIL as u64
            sys_msg_reply(sender, reply as u8*, 8)
        }
    } else if op == (Wm.OP_BEGIN_FILE_DRAG as u64) {
        if slot_arg >= 0 && slot_arg < Wm.MAX_WINDOWS && windows[slot_arg].used {
            let drag_path: u8* = (msg as u8*) + 16
            begin_file_drag(slot_arg, drag_path)
            rep[0] = Wm.STATUS_OK as u64
            sys_msg_reply(sender, reply as u8*, 8)
        } else {
            rep[0] = Wm.STATUS_FAIL as u64
            sys_msg_reply(sender, reply as u8*, 8)
        }
    } else if op == (Wm.OP_STATS as u64) {
        rep[0] = Wm.STATUS_OK as u64
        rep[1] = wm_frames_presented
        rep[2] = wm_full_redraws
        rep[3] = wm_rect_presents
        rep[4] = wm_skipped_frames
        rep[5] = 0
        if wm_dirty {
            rep[5] = 1
        }
        sys_msg_reply(sender, reply as u8*, 48)
    } else {
        rep[0] = Wm.STATUS_FAIL as u64
        sys_msg_reply(sender, reply as u8*, 8)
    }
}

func _start(argc: u64, argv: u64*) {
    sys_putln("wm: starting")

    let i: i64 = 0
    while i < Wm.MAX_WINDOWS {
        windows[i].used = false
        windows[i].minimized = false
        windows[i].maximized = false
        windows[i].owner_pid = -1
        windows[i].close_requested = false
        z_order[i] = 0
        i = i + 1
    }
    z_count = 0
    drag_file_active = false
    drag_file_source = -1
    pending_drop_valid = false
    pending_drop_slot = -1
    taskbar_drag_active = false
    taskbar_drag_slot = -1
    taskbar_drag_target = -1

    if sys_register("wm") == RT_SYS_ERR {
        sys_putln("wm: register failed")
        rt_exit(1)
    }

    let info: u64[3]
    if sys_fb_info(info as u64*) == RT_SYS_ERR {
        sys_putln("wm: no framebuffer")
        rt_exit(1)
    }
    fb_width = info[0]
    fb_height = info[1]
    fb_pitch = info[2]

    fb = sys_fb_map()
    if fb == null {
        sys_putln("wm: fb_map failed")
        rt_exit(1)
    }

    // Back buffer, exactly the real framebuffer's own size (fb_pitch *
    // fb_height, not width * height - pitch can include padding past
    // the visible width) - see present_frame's own doc comment for why
    // everything renders here instead of straight to `fb`.
    let backbuf_bytes: u64 = fb_pitch * fb_height
    let backbuf_pages: u64 = (backbuf_bytes + 4095) / 4096
    backbuf = sys_alloc_pages(backbuf_pages)
    if backbuf == null {
        sys_putln("wm: backbuf alloc failed")
        rt_exit(1)
    }

    let arena_bytes: u64 = (Wm.WIN_BYTES as u64) * (Wm.MAX_WINDOWS as u64)
    let arena_pages: u64 = (arena_bytes + 4095) / 4096
    arena = sys_shm_create(arena_pages)
    if arena == null {
        sys_putln("wm: shm_create failed")
        rt_exit(1)
    }

    // Load the embedded wallpaper photo and cursor image
    sys_putln("wm: loading wallpaper...")
    let wallpaper_data: u8* = load_wallpaper_photo()
    wallpaper_tile = load_embedded_image(wallpaper_data)

    sys_putln("wm: loading cursor...")
    let cursor_data: u8* = load_cursor_photo()
    cursor_img = load_embedded_image(cursor_data)

    let terminal_icon_data: u8* = load_start_icon_terminal()
    start_icon_terminal = load_embedded_image(terminal_icon_data)
    let file_icon_data: u8* = load_start_icon_file()
    start_icon_file = load_embedded_image(file_icon_data)
    let app_icon_data: u8* = load_start_icon_app()
    start_icon_app = load_embedded_image(app_icon_data)
    launcher_clear_query()

    sys_putln("wm: ready")
    add_notification("Desktop ready" as u8*, "Start menu, tray, and notifications are online" as u8*, 1)

    // Phase 1: reactive, but now watching for *either* of two triggers
    // to start owning the screen - a client creating the first window
    // (as before), or the user explicitly switching keyboard focus to
    // windowing (F12) even with zero windows open. The second trigger is
    // what lets the always-on taskbar (see draw_taskbar) actually
    // deliver on its whole reason for existing: launching the very
    // *first* app without the console. Without it, the taskbar would
    // only ever appear after a window already existed, which means it
    // could only help with the second app onward. A short sys_sleep
    // instead of blocking in sys_msg_recv, since there are now two
    // separate things to poll instead of one thing to block on.
    while !active {
        let msg: u8[128]
        let sender: u64 = sys_msg_try_recv(msg as u8*, 128)
        if sender != RT_SYS_ERR {
            handle_request(sender, msg as u8*)
        }
        if sys_focus_state() == (FOCUS_WM as u64) {
            active = true
        }
        if !active {
            sys_sleep(50)
        }
    }

    // Phase 2: at least one window exists now. Non-blocking try_recv
    // instead of recv from here on, since this loop also has the mouse
    // and the periodic redraw to get to every tick regardless of whether
    // a client happens to be talking to it this instant - a blocking
    // recv would starve both exactly as long as no client sends
    // anything.
    let dragging: bool = false
    let drag_slot: i64 = -1
    let drag_dx: i64 = 0
    let drag_dy: i64 = 0
    let resizing: bool = false
    let resize_slot: i64 = -1
    // Offset between the click point and the window's actual bottom-right
    // corner at the moment the grip was grabbed - see its own doc comment
    // where it's computed, below.
    let resize_off_x: i64 = 0
    let resize_off_y: i64 = 0
    let prev_left: bool = false
    let prev_right: bool = false
    let prev_mx: i64 = -1
    let prev_my: i64 = -1
    let clock_accum_ms: u64 = 0

    while true {
        let msg: u8[128]
        let sender: u64 = sys_msg_try_recv(msg as u8*, 128)
        if sender != RT_SYS_ERR {
            handle_request(sender, msg as u8*)
        }

        if start_menu_open {
            let menu_key: u64 = sys_kbd_poll()
            if menu_key != 0 {
                launcher_key(menu_key)
                wm_dirty = true
            }
        }

        let mstate: u64 = sys_mouse_poll()
        let mx: i64 = (mstate & 0x3FF) as i64
        let my: i64 = ((mstate >> 10) & 0x3FF) as i64
        let mleft: bool = (mstate & (1 << 20)) != 0
        let mright: bool = (mstate & (1 << 21)) != 0

        // Update global mouse state for clients
        global_mouse_x = mx
        global_mouse_y = my
        global_mouse_left = mleft
        global_mouse_right = mright
        // Raw 8-bit two's-complement byte in bits 21-28 (see
        // sys_mouse_poll's own doc comment) - recovered the same way
        // KEY_UP/DOWN/etc's own u8-sign hazard is, elsewhere in this
        // codebase. Accumulated into wheel_accum (declared with the
        // other per-tick state below) rather than used directly, since
        // wm ticks every ~15ms but a client's own OP_POLL_INPUT calls
        // may come less often - dropping notches between polls would
        // make scrolling feel unreliable.
        let wheel_raw: i64 = ((mstate >> 21) & 0xFF) as i64
        if wheel_raw >= 128 {
            wheel_raw = wheel_raw - 256
        }
        wheel_accum = wheel_accum + wheel_raw

        if file_dialog_active {
            let dialog_key: u64 = sys_kbd_poll()
            if dialog_key != 0 {
                file_dialog_key(dialog_key)
            }
        }

        if taskbar_drag_active && mleft {
            let clock_x: i64 = (fb_width as i64) - (CLOCK_W as i64) - 8
            let tray_x: i64 = clock_x - (TRAY_W as i64) - 6
            let cpu_x: i64 = tray_x - (CPU_GRAPH_W as i64) - 6
            taskbar_drag_target = hit_test_window_taskbar(mx, my, cpu_x - 6)
        }

        // Priority order on a fresh press: close button, then resize
        // grip, then the taskbar, then an ordinary titlebar drag - close/
        // resize/taskbar are all small, specific targets that would
        // otherwise be swallowed by a broader titlebar-drag hit test if
        // they overlapped it.
        if !file_dialog_active && mleft && !prev_left {
            let close_hit: i64 = hit_test_close_button(mx, my)
            let minimize_hit: i64 = hit_test_title_button(mx, my, 1)
            let maximize_hit: i64 = hit_test_title_button(mx, my, 2)
            let resize_hit: i64 = hit_test_resize_grip(mx, my)
            let taskbar_hit: i64 = hit_test_taskbar(mx, my)

            if close_hit >= 0 {
                windows[close_hit].close_requested = true
                z_bring_to_front(close_hit)
                focused = close_hit
                wm_dirty = true
            } else if minimize_hit >= 0 {
                minimize_window(minimize_hit)
                close_start_menu()
                wm_dirty = true
            } else if maximize_hit >= 0 {
                toggle_maximize_window(maximize_hit)
                focused = maximize_hit
                z_bring_to_front(maximize_hit)
                close_start_menu()
                wm_dirty = true
            } else if resize_hit >= 0 && !windows[resize_hit].maximized {
                resizing = true
                resize_slot = resize_hit
                focused = resize_hit
                resize_off_x = (windows[resize_hit].win_x as i64) + (windows[resize_hit].vis_w as i64) - mx
                resize_off_y = (windows[resize_hit].win_y as i64) + (TITLEBAR_H as i64) + (windows[resize_hit].vis_h as i64) - my
                z_bring_to_front(resize_hit)
                wm_dirty = true
            } else if taskbar_hit == START_HIT {
                if start_menu_open {
                    close_start_menu()
                } else {
                    open_start_menu()
                }
                wm_dirty = true
            } else if taskbar_hit == TRAY_HIT {
                notify_unread = 0
                add_notification("System status" as u8*, "Window manager and tray are running" as u8*, 0)
                close_start_menu()
                wm_dirty = true
            } else if taskbar_hit <= WINDOW_BUTTON_HIT_BASE && taskbar_hit > WINDOW_BUTTON_HIT_BASE - Wm.MAX_WINDOWS {
                let win_slot: i64 = WINDOW_BUTTON_HIT_BASE - taskbar_hit
                restore_window(win_slot)
                focused = win_slot
                z_bring_to_front(win_slot)
                close_start_menu()
                wm_dirty = true
            } else if taskbar_hit >= 0 {
                taskbar_drag_active = true
                taskbar_drag_slot = taskbar_hit
                taskbar_drag_start_x = mx
                taskbar_drag_start_y = my
                taskbar_drag_target = taskbar_hit
            } else if start_menu_open {
                close_start_menu()
                wm_dirty = true
            } else {
                let desktop_hit: i64 = hit_test_desktop_icon(mx, my)
                if desktop_hit >= 0 {
                    desktop_icon_launch(desktop_hit)
                    wm_dirty = true
                } else {
                    let hit: i64 = hit_test_titlebar(mx, my)
                    if hit >= 0 {
                        dragging = true
                        drag_slot = hit
                        drag_dx = mx - (windows[hit].win_x as i64)
                        drag_dy = my - (windows[hit].win_y as i64)
                        focused = hit
                        z_bring_to_front(hit)
                        wm_dirty = true
                    }
                }
            }
        } else if !mleft && prev_left {
            if taskbar_drag_active {
                let dx: i64 = mx - taskbar_drag_start_x
                let dy: i64 = my - taskbar_drag_start_y
                if dx * dx + dy * dy < TASKBAR_DRAG_THRESHOLD * TASKBAR_DRAG_THRESHOLD {
                    taskbar_launch(taskbar_drag_slot)
                    close_start_menu()
                    wm_dirty = true
                } else if taskbar_drag_target >= 0 && taskbar_drag_target != taskbar_drag_slot {
                    reorder_taskbar_button(taskbar_drag_slot, taskbar_drag_target)
                    focused = taskbar_drag_slot
                    z_bring_to_front(taskbar_drag_slot)
                    close_start_menu()
                    wm_dirty = true
                }
                taskbar_drag_active = false
                taskbar_drag_slot = -1
                taskbar_drag_target = -1
            }
            if drag_file_active {
                let drop_slot: i64 = hit_test_window_under_point(mx, my)
                queue_file_drop(drop_slot)
            }
            if dragging && drag_slot >= 0 {
                apply_drag_snap(drag_slot, mx, my)
                wm_dirty = true
            }
            dragging = false
            drag_slot = -1
            resizing = false
            resize_slot = -1
        }
        if !file_dialog_active && mright && !prev_right {
            let taskbar_hit: i64 = hit_test_taskbar(mx, my)
            if taskbar_hit >= 0 && taskbar_hit < taskbar_count {
                toggle_taskbar_pin(taskbar_hit)
            }
        }
        prev_left = mleft
        prev_right = mright

        if dragging && drag_slot >= 0 {
            let max_wx: i64 = (fb_width as i64) - (windows[drag_slot].vis_w as i64)
            let max_wy: i64 = (fb_height as i64) - (windows[drag_slot].vis_h as i64) - (TITLEBAR_H as i64) - 32
            windows[drag_slot].win_x = clampi(mx - drag_dx, 0, max_wx) as u64
            windows[drag_slot].win_y = clampi(my - drag_dy, 0, max_wy) as u64
            wm_dirty = true
        }

        if resizing && resize_slot >= 0 {
            let ox: i64 = windows[resize_slot].win_x as i64
            let oy: i64 = (windows[resize_slot].win_y as i64) + (TITLEBAR_H as i64)
            let max_w: i64 = max_visible_w_for(resize_slot)
            let max_h: i64 = max_visible_h_for(resize_slot)
            let new_w: i64 = clampi(mx + resize_off_x - ox, MIN_VIS_W as i64, max_w)
            let new_h: i64 = clampi(my + resize_off_y - oy, MIN_VIS_H as i64, max_h)
            windows[resize_slot].vis_w = new_w as u64
            windows[resize_slot].vis_h = new_h as u64
            wm_dirty = true
        }

        let mouse_moved: bool = mx != prev_mx || my != prev_my
        clock_accum_ms = clock_accum_ms + 15
        if clock_accum_ms >= 1000 {
            clock_accum_ms = 0
            update_cpu_graph_sample()
            wm_dirty = true
        }

        if wm_dirty || mouse_moved {
            fill_backdrop()
            redraw_windows(mx, my)
            present_frame()
            wm_full_redraws = wm_full_redraws + 1
            wm_dirty = false
            prev_mx = mx
            prev_my = my
        } else {
            wm_skipped_frames = wm_skipped_frames + 1
        }
        wm_uptime_ms = wm_uptime_ms + 15
        sys_sleep(15)
    }
}
