    // Draws one glyph into `buf` (a buf_w x buf_h uint32 pixel buffer, row-
    // major - exactly the shape wm_client.llpl's wm_buffer() returns) at
    // pixel position (x, y), bounds-checked per-pixel against buf_w/buf_h
    // so a glyph straddling the buffer's right/bottom edge just clips
    // instead of writing out of bounds. Anything outside the printable
    // ASCII range (32-126) draws as a blank cell rather than garbage.
    func draw_char(buf: uint32*, buf_w: u64, buf_h: u64, x: u64, y: u64, c: char, fg: uint32, bg: uint32) {
        let code: i64 = c as i64
        if code < 32 || code > 126 {
            code = 32
        }
        let glyph_offset: i64 = (code - 32) * GLYPH_HEIGHT

        let row: i64 = 0
        while row < GLYPH_HEIGHT {
            let py: i64 = (y as i64) + row
            if py >= 0 && py < (buf_h as i64) {
                // `& 255` undoes char's signedness before testing bits - a
                // glyph row byte like 254 would otherwise read back
                // negative and corrupt every bit test below.
                let bits: i64 = (font_data[glyph_offset + row] as i64) & 255
                let col: i64 = 0
                while col < GLYPH_WIDTH {
                    let px: i64 = (x as i64) + col
                    if px >= 0 && px < (buf_w as i64) {
                        let mask: i64 = 128 >> col
                        let color: uint32 = bg
                        if (bits & mask) != 0 {
                            color = fg
                        }
                        buf[(py as u64) * buf_w + (px as u64)] = color
                    }
                    col = col + 1
                }
            }
            row = row + 1
        }
    }

    func draw_string(buf: uint32*, buf_w: u64, buf_h: u64, x: u64, y: u64, str: char*, fg: uint32, bg: uint32) {
        let i: i64 = 0
        let cur_x: u64 = x
        while str[i] != 0 {
            draw_char(buf, buf_w, buf_h, cur_x, y, str[i], fg, bg)
            cur_x = cur_x + (GLYPH_WIDTH as u64)
            i = i + 1
        }
    }
}
