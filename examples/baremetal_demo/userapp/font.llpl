        0, 0, 120, 126, 70, 98, 70, 126, 124, 76, 100, 102, 66, 0, 0, 0, // 82 'R'
        0, 0, 24, 126, 102, 96, 96, 60, 14, 6, 66, 126, 60, 0, 0, 0, // 83 'S'
        0, 0, 126, 126, 24, 24, 24, 24, 24, 24, 24, 24, 24, 0, 0, 0, // 84 'T'
        0, 0, 66, 102, 66, 66, 66, 66, 66, 66, 102, 126, 60, 0, 0, 0, // 85 'U'
