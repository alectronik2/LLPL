// Shared 8x16 bitmap font for ring-3 clients that want to draw text into
// their own window buffer (editor.llpl, filebrowser.llpl) - the same
// glyph data fb.llpl's Framebuffer.draw_char already uses for the kernel
// boot console, just copied here rather than shared, since fb.llpl's
// copy writes straight to the kernel's own framebuffer/pitch state and
// this needs to write into an arbitrary caller-supplied uint32* buffer
// (a client's own arena slice, addressed by its own width) instead.

namespace Font {
    const GLYPH_WIDTH = 8
    const GLYPH_HEIGHT = 16

    // Row-major, GLYPH_HEIGHT bytes per glyph, one glyph per printable
    // ASCII code point (32 ' ' through 126 '~') - see fb.llpl's own copy
    // of this table for the full per-glyph comments.
