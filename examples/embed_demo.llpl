extern func puts(s: string) -> int

func print_int(label: string, value: int) {
    let buf: char[96]
    ksnprintf(buf as string, 96, "%s = %d", label, value)
    puts(buf as string)
}

func main() -> int {
    let font = embed("sample_font.bin")

    print_int("font bytes", font.len as int)
    print_int("first byte", font.data[0] as int)

    return 0
}
