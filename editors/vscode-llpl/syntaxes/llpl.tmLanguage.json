{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "LLPL",
    "scopeName": "source.llpl",
    "fileTypes": ["llpl"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#operator-declaration" },
        { "include": "#namespace-declaration" },
        { "include": "#enum-declaration" },
        { "include": "#struct-declaration" },
        { "include": "#class-declaration" },
        { "include": "#trait-declaration" },
        { "include": "#impl-declaration" },
        { "include": "#function-declaration" },
        { "include": "#alias-declaration" },
        { "include": "#macro-declaration" },
        { "include": "#control-keywords" },
        { "include": "#other-keywords" },
        { "include": "#modifier-keywords" },
        { "include": "#sizeof-keyword" },
        { "include": "#asm-statement" },
        { "include": "#asm-keyword" },
        { "include": "#language-constants" },
        { "include": "#self-variable" },
        { "include": "#type-annotation" },
        { "include": "#return-type" },
        { "include": "#new-expression" },
        { "include": "#as-expression" },
        { "include": "#primitive-types" },
        { "include": "#macro-invocation" },
        { "include": "#function-call" },
        { "include": "#member-access" },
        { "include": "#operators" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.llpl",
                    "begin": "/\\*",
                    "end": "\\*/"
                },
                {
                    "name": "comment.line.double-slash.llpl",
                    "begin": "//",
                    "end": "$"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.llpl",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                { "include": "#string-interpolation" },
                {
                    "name": "constant.character.escape.llpl",
                    "match": "\\\\(x[0-9a-fA-F]{1,2}|[nrt0\\\\\"ex])"
                }
            ]
        },
        "string-interpolation": {
            "comment": "\\(expr) inside a string literal - LLPL's string interpolation. The delimiter's own '\\(' / ')' consume one level of nesting; #interp-parens (mirroring #asm-parens below) recurses for any further '(...)' inside the embedded expression, e.g. \\(foo(1, 2)).",
            "name": "meta.interpolation.llpl",
            "begin": "\\\\\\(",
            "beginCaptures": {
                "0": { "name": "punctuation.section.embedded.begin.llpl" }
            },
            "end": "\\)",
            "endCaptures": {
                "0": { "name": "punctuation.section.embedded.end.llpl" }
            },
            "patterns": [
                { "include": "#comments" },
                { "include": "#strings" },
                { "include": "#numbers" },
                { "include": "#language-constants" },
                { "include": "#self-variable" },
                { "include": "#as-expression" },
                { "include": "#macro-invocation" },
                { "include": "#function-call" },
                { "include": "#member-access" },
                { "include": "#operators" },
                { "include": "#interp-parens" },
                { "include": "#punctuation" }
            ]
        },
        "interp-parens": {
            "begin": "\\(",
            "end": "\\)",
            "patterns": [
                { "include": "#comments" },
                { "include": "#strings" },
                { "include": "#numbers" },
                { "include": "#language-constants" },
                { "include": "#self-variable" },
                { "include": "#as-expression" },
                { "include": "#macro-invocation" },
                { "include": "#function-call" },
                { "include": "#member-access" },
                { "include": "#operators" },
                { "include": "#interp-parens" },
                { "include": "#punctuation" }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.llpl",
                    "match": "\\b0[xX][0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.binary.llpl",
                    "match": "\\b0[bB][01]+\\b"
                },
                {
                    "name": "constant.numeric.octal.llpl",
                    "match": "\\b0[oO][0-7]+\\b"
                },
                {
                    "name": "constant.numeric.decimal.llpl",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "namespace-declaration": {
            "match": "\\b(namespace)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.other.namespace.llpl" },
                "2": { "name": "entity.name.namespace.llpl" }
            }
        },
        "enum-declaration": {
            "match": "\\b(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.other.enum.llpl" },
                "2": { "name": "entity.name.type.llpl" }
            }
        },
        "struct-declaration": {
            "match": "\\b(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.other.struct.llpl" },
                "2": { "name": "entity.name.type.llpl" }
            }
        },
        "class-declaration": {
            "match": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.other.class.llpl" },
                "2": { "name": "entity.name.class.llpl" }
            }
        },
        "operator-declaration": {
            "comment": "func operator+(...) - the overloaded operator symbol isn't identifier syntax, so it needs its own rule ahead of function-declaration.",
            "match": "\\b(func)\\s+(operator)\\s*(==|!=|<=|>=|<<|>>|[+\\-*/%=<>!&|^~])",
            "captures": {
                "1": { "name": "keyword.other.function.llpl" },
                "2": { "name": "keyword.other.operator.llpl" },
                "3": { "name": "keyword.operator.llpl" }
            }
        },
        "function-declaration": {
            "match": "\\b(func)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.other.function.llpl" },
                "2": { "name": "entity.name.function.llpl" }
            }
        },
        "alias-declaration": {
            "match": "\\b(alias)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.other.alias.llpl" },
                "2": { "name": "entity.name.function.llpl" }
            }
        },
        "macro-declaration": {
            "match": "\\b(macro)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.other.macro.llpl" },
                "2": { "name": "entity.name.function.macro.llpl" }
            }
        },
        "macro-invocation": {
            "comment": "NAME!(...) or Ns.NAME!(...) - the '!' right before '(' is what marks this as a macro call rather than a plain function call.",
            "match": "\\b([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\s*(!)\\s*(?=\\()",
            "captures": {
                "1": { "name": "entity.name.function.macro.llpl" },
                "2": { "name": "keyword.operator.macro.llpl" }
            }
        },
        "control-keywords": {
            "match": "\\b(if|else|while|for|foreach|in|return|defer|match|case|default|unless)\\b",
            "name": "keyword.control.llpl"
        },
        "other-keywords": {
            "match": "\\b(import|let|const|extern|constructor|destructor|quote|unquote)\\b",
            "name": "keyword.other.llpl"
        },
        "modifier-keywords": {
            "match": "\\b(packed|interrupt|volatile)\\b",
            "name": "storage.modifier.llpl"
        },
        "sizeof-keyword": {
            "match": "\\bsizeof\\b",
            "name": "keyword.other.sizeof.llpl support.function.sizeof.llpl"
        },
        "trait-declaration": {
            "match": "\\b(trait)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.other.trait.llpl" },
                "2": { "name": "entity.name.type.llpl" }
            }
        },
        "impl-declaration": {
            "comment": "impl TraitName for TargetType { ... } - both names are types, not declared identifiers, so entity.name.type (not entity.name.class/struct) fits either one.",
            "match": "\\b(impl)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(for)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.other.impl.llpl" },
                "2": { "name": "entity.name.type.llpl" },
                "3": { "name": "keyword.other.for.llpl" },
                "4": { "name": "entity.name.type.llpl" }
            }
        },
        "asm-keyword": {
            "match": "\\basm\\b",
            "name": "keyword.other.asm.llpl support.function.asm.llpl"
        },
        "asm-statement": {
            "comment": "asm(\"template\" : outputs : inputs : clobbers) - owns everything through its matching close-paren so the ':' section separators aren't misread as type annotations.",
            "name": "meta.asm.llpl",
            "begin": "\\b(asm)\\b\\s*(?=\\()",
            "beginCaptures": {
                "1": { "name": "keyword.other.asm.llpl support.function.asm.llpl" }
            },
            "end": "(?<=\\))",
            "patterns": [
                { "include": "#asm-parens" }
            ]
        },
        "asm-parens": {
            "begin": "\\(",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.parameters.begin.llpl" }
            },
            "end": "\\)",
            "endCaptures": {
                "0": { "name": "punctuation.definition.parameters.end.llpl" }
            },
            "patterns": [
                { "include": "#comments" },
                { "include": "#strings" },
                { "include": "#numbers" },
                { "include": "#self-variable" },
                {
                    "match": ":",
                    "name": "punctuation.separator.asm.llpl"
                },
                {
                    "match": ",",
                    "name": "punctuation.separator.comma.llpl"
                },
                { "include": "#member-access" },
                { "include": "#function-call" },
                { "include": "#operators" },
                { "include": "#asm-parens" },
                {
                    "match": "[A-Za-z_][A-Za-z0-9_]*",
                    "name": "variable.other.llpl"
                }
            ]
        },
        "language-constants": {
            "match": "\\b(true|false|null)\\b",
            "name": "constant.language.llpl"
        },
        "self-variable": {
            "match": "\\bself\\b",
            "name": "variable.language.self.llpl"
        },
        "primitive-types": {
            "match": "\\b(int|uint|int16|uint16|int32|uint32|char|bool|void)\\b",
            "name": "storage.type.primitive.llpl"
        },
        "type-name": {
            "patterns": [
                { "include": "#generic-type-args" },
                { "include": "#closure-type-parens" },
                {
                    "match": "\\b(int|uint|int16|uint16|int32|uint32|char|bool|void)\\b",
                    "name": "storage.type.primitive.llpl"
                },
                {
                    "match": "[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*",
                    "name": "entity.name.type.llpl"
                },
                {
                    "match": "->",
                    "name": "keyword.operator.arrow.llpl"
                },
                {
                    "match": "\\?",
                    "name": "keyword.operator.nullable.llpl"
                },
                {
                    "match": "\\*",
                    "name": "keyword.operator.pointer.llpl"
                },
                {
                    "match": "\\[|\\]",
                    "name": "punctuation.definition.array.llpl"
                },
                {
                    "match": "(:)\\s*([0-9]+)",
                    "captures": {
                        "1": { "name": "punctuation.separator.bitfield.llpl" },
                        "2": { "name": "constant.numeric.decimal.llpl" }
                    }
                }
            ]
        },
        "generic-type-args": {
            "comment": "Pair<A, B> in a type position - a nested region (not a plain match) so its internal commas don't prematurely end the outer type-annotation/return-type region, which stops at the first bare comma/paren/brace/equals/semicolon it sees.",
            "begin": "<",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.typeparameters.begin.llpl" }
            },
            "end": ">",
            "endCaptures": {
                "0": { "name": "punctuation.definition.typeparameters.end.llpl" }
            },
            "patterns": [
                { "include": "#comments" },
                { "include": "#type-name" },
                {
                    "match": ",",
                    "name": "punctuation.separator.comma.llpl"
                }
            ]
        },
        "closure-type-parens": {
            "comment": "(T1, T2) -> R closure/function-pointer type - same nested-region reasoning as generic-type-args, for the commas between parameter types.",
            "begin": "\\(",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.parameters.begin.llpl" }
            },
            "end": "\\)",
            "endCaptures": {
                "0": { "name": "punctuation.definition.parameters.end.llpl" }
            },
            "patterns": [
                { "include": "#comments" },
                { "include": "#type-name" },
                {
                    "match": ",",
                    "name": "punctuation.separator.comma.llpl"
                }
            ]
        },
        "type-annotation": {
            "begin": "(:)(?!:)\\s*",
            "beginCaptures": {
                "1": { "name": "punctuation.separator.annotation.llpl" }
            },
            "end": "(?=[,\\)\\{=;\\n]|$)",
            "patterns": [
                { "include": "#comments" },
                { "include": "#type-name" }
            ]
        },
        "return-type": {
            "begin": "(->)\\s*",
            "beginCaptures": {
                "1": { "name": "keyword.operator.arrow.llpl" }
            },
            "end": "(?=[\\{;\\n]|$)",
            "patterns": [
                { "include": "#comments" },
                { "include": "#type-name" }
            ]
        },
        "new-expression": {
            "match": "\\b(new)\\s+([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\b",
            "captures": {
                "1": { "name": "keyword.other.new.llpl" },
                "2": { "name": "entity.name.type.llpl" }
            }
        },
        "as-expression": {
            "match": "\\b(as)\\s+([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)(\\*)?",
            "captures": {
                "1": { "name": "keyword.other.as.llpl" },
                "2": { "name": "storage.type.primitive.llpl entity.name.type.llpl" },
                "3": { "name": "keyword.operator.pointer.llpl" }
            }
        },
        "function-call": {
            "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
            "name": "entity.name.function.call.llpl"
        },
        "member-access": {
            "match": "(\\.)\\s*([A-Za-z_][A-Za-z0-9_]*)\\b(?!\\s*\\()",
            "captures": {
                "1": { "name": "punctuation.accessor.llpl" },
                "2": { "name": "variable.other.property.llpl" }
            }
        },
        "operators": {
            "match": "(==|!=|<=|>=|&&|\\|\\||\\|>|<<|>>|->|=>|[+\\-*/%=<>!&|^~?])",
            "name": "keyword.operator.llpl"
        },
        "punctuation": {
            "patterns": [
                {
                    "match": "[{}]",
                    "name": "punctuation.definition.block.llpl"
                },
                {
                    "match": "[\\[\\]]",
                    "name": "punctuation.definition.array.llpl"
                },
                {
                    "match": "[()]",
                    "name": "punctuation.definition.parameters.llpl"
                },
                {
                    "match": ",",
                    "name": "punctuation.separator.comma.llpl"
                },
                {
                    "match": ":",
                    "name": "punctuation.separator.colon.llpl"
                },
                {
                    "match": "\\.",
                    "name": "punctuation.accessor.llpl"
                }
            ]
        }
    }
}
