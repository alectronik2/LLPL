extern func puts(s: string) -> i64

func print_int(label: string, value: i64) {
    let buf: char[96]
    ksnprintf(buf as string, 96, "%s = %d", label, value)
    puts(buf as string)
}

func main() -> i64 {
    let asset = embed("embed_asset.txt")

    print_int("len", asset.len as i64)
    print_int("first", asset.data[0] as i64)
    print_int("last", asset.data[asset.len as i64 - 1] as i64)

    return 0
}
