{
    "name": "llplbuild",
    "description": "YAML-configured build tool for LLPL bare-metal targets",
    "authors": ["LLPL Team"],
    "license": "MIT",
    "targetType": "executable",
    "targetName": "llplbuild",
    "mainSourceFile": "source/main.d",
    "sourcePaths": ["source"],
    "dependencies": {
        "dyaml": "~>0.10.0"
    },
    "buildTypes": {
        "release": {
            "buildOptions": ["releaseMode", "optimize", "inline"]
        }
    }
}
